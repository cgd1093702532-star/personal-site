@import "../../styles/common.wxss";

.my-recruit {
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  background: var(--color-bg-subtle);
}

.my-recruit__tabs {
  display: flex;
  background: var(--color-bg-page);
  border-bottom: 1rpx solid var(--color-divider);
}

.my-recruit__tab {
  flex: 1;
  padding: 24rpx 8rpx;
  text-align: center;
  font-size: var(--text-caption);
  color: var(--color-text-secondary);
  white-space: nowrap;
}

.my-recruit__tab--active {
  color: var(--color-primary);
  font-weight: 600;
  border-bottom: 4rpx solid var(--color-primary);
}

.my-recruit__overview {
  display: flex;
  gap: 16rpx;
  padding: 24rpx var(--space-page-x);
}

.my-recruit__stat-card {
  flex: 1;
  padding: 24rpx 20rpx;
  border-radius: var(--radius-md);
  border: 1rpx solid transparent;
}

.my-recruit__stat-card--signup {
  background: linear-gradient(135deg, #eef4ff 0%, #f6f9ff 100%);
  border-color: rgba(27, 87, 156, 0.12);
}

.my-recruit__stat-card--income {
  background: linear-gradient(135deg, #fff8e6 0%, #fffdf5 100%);
  border-color: rgba(254, 207, 19, 0.35);
}

.my-recruit__stat-num {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 1.2;
}

.my-recruit__stat-label {
  display: block;
  margin-top: 8rpx;
  font-size: var(--text-caption);
  color: var(--color-text-secondary);
}

.my-recruit__list {
  padding: 0 var(--space-page-x);
}

.my-recruit__card {
  margin-bottom: 20rpx;
  padding: 24rpx 24rpx 20rpx;
  background: var(--color-bg-page);
  border-radius: var(--radius-md);
  border-left: 6rpx solid var(--color-primary);
  box-shadow: 0 4rpx 16rpx rgba(27, 87, 156, 0.06);
}

.my-recruit__card--draft {
  padding: 28rpx;
  border-left: none;
  border: 1rpx solid rgba(27, 87, 156, 0.12);
  background: linear-gradient(180deg, #eef4ff 0%, #f6f9ff 100%);
  box-shadow: none;
}

.my-recruit__draft-head {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.my-recruit__draft-icon-wrap {
  flex-shrink: 0;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-md);
  background: rgba(255, 255, 255, 0.85);
  font-size: 36rpx;
  line-height: 1;
}

.my-recruit__draft-body {
  flex: 1;
  min-width: 0;
}

.my-recruit__draft-body .my-recruit__title {
  display: block;
}

.my-recruit__draft-hint {
  display: block;
  margin-top: 6rpx;
  font-size: var(--text-caption);
  color: var(--color-text-secondary);
}

.my-recruit__draft-meta {
  padding: 16rpx 20rpx;
  border-radius: var(--radius-md);
  background: rgba(255, 255, 255, 0.72);
}

.my-recruit__draft-meta .my-recruit__row {
  margin-bottom: 6rpx;
}

.my-recruit__draft-meta .my-recruit__row:last-child {
  margin-bottom: 0;
}

.my-recruit__draft-plan {
  display: block;
  font-size: var(--text-caption);
  color: var(--color-text-body);
  line-height: 36rpx;
}

.my-recruit__actions--draft {
  margin-top: 20rpx;
}

.my-recruit__actions--draft .my-recruit__btn--primary {
  flex: 1.6;
}

.my-recruit__btn--ghost {
  background: transparent;
  color: var(--color-text-secondary);
  border: 1rpx solid rgba(27, 87, 156, 0.18);
}

.my-recruit__card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.my-recruit__title {
  flex: 1;
  min-width: 0;
  font-size: var(--text-card-title);
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 40rpx;
}

.my-recruit__badge {
  flex-shrink: 0;
  padding: 4rpx 14rpx;
  border-radius: var(--radius-pill);
  font-size: var(--text-micro);
  font-weight: 500;
}

.my-recruit__badge--recruiting {
  background: rgba(254, 207, 19, 0.35);
  color: #8a6d00;
}

.my-recruit__badge--ongoing {
  background: rgba(0, 199, 119, 0.2);
  color: var(--color-course-tag);
}

.my-recruit__badge--closed,
.my-recruit__badge--ended {
  background: var(--color-bg-gray);
  color: var(--color-text-secondary);
}

.my-recruit__badge--draft {
  background: rgba(27, 87, 156, 0.1);
  color: var(--color-primary);
}

.my-recruit__row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 10rpx;
}

.my-recruit__row-icon {
  flex-shrink: 0;
  font-size: 24rpx;
  line-height: 1;
}

.my-recruit__row-text {
  font-size: var(--text-caption);
  color: var(--color-text-secondary);
  line-height: 36rpx;
}

.my-recruit__signup-row {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 8rpx;
}

.my-recruit__signup-main {
  flex: 1;
  min-width: 0;
}

.my-recruit__signup-text {
  font-size: var(--text-caption);
  color: var(--color-text-body);
}

.my-recruit__bar {
  height: 10rpx;
  margin-top: 10rpx;
  background: var(--color-divider);
  border-radius: 5rpx;
  overflow: hidden;
}

.my-recruit__bar-inner {
  height: 100%;
  background: var(--color-primary);
  border-radius: 5rpx;
}

.my-recruit__fee {
  flex-shrink: 0;
  font-size: var(--text-body);
  font-weight: 600;
  color: var(--color-price);
}

.my-recruit__fee--muted {
  color: var(--color-text-muted);
}

.my-recruit__actions {
  display: flex;
  gap: 12rpx;
  margin-top: 20rpx;
}

.my-recruit__btn {
  flex: 1;
  min-width: 0;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  border-radius: var(--radius-md);
  font-size: var(--text-caption);
  font-weight: 500;
}

.my-recruit__btn-icon {
  font-size: 24rpx;
  line-height: 1;
}

.my-recruit__btn--primary {
  flex: 1.4;
  background: var(--color-primary);
  color: var(--color-text-inverse);
}

.my-recruit__btn--outline {
  background: var(--color-bg-page);
  color: var(--color-text-body);
  border: 1rpx solid var(--color-divider);
}

.my-recruit__btn--danger {
  background: rgba(244, 117, 40, 0.12);
  color: var(--color-activity);
}

.my-recruit__btn:active {
  opacity: 0.88;
}

.my-recruit__empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 48rpx 160rpx;
  text-align: center;
}

.my-recruit__empty-icon {
  font-size: 80rpx;
  line-height: 1;
  margin-bottom: 24rpx;
}

.my-recruit__empty-title {
  font-size: var(--text-section-title);
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 44rpx;
}

.my-recruit__empty-hint {
  margin-top: 12rpx;
  font-size: var(--text-caption);
  color: var(--color-text-secondary);
  line-height: 40rpx;
  max-width: 480rpx;
}

.my-recruit__empty-btn {
  margin-top: 32rpx;
  padding: 0 48rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: var(--radius-md);
  background: var(--color-primary);
  color: var(--color-text-inverse);
  font-size: var(--text-body);
  font-weight: 500;
}

.my-recruit__empty-btn:active {
  opacity: 0.88;
}

@import "../../styles/common.wxss";

.order-voucher {
  min-height: 100vh;
  padding: 24rpx;
  background: #f5f5f5;
  box-sizing: border-box;
}

.order-voucher__card {
  margin-bottom: 24rpx;
  padding: 32rpx;
  background: #ffffff;
  border-radius: 20rpx;
}

.order-voucher__event-title {
  display: block;
  margin-bottom: 24rpx;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.4;
  color: #222222;
}

.order-voucher__meta {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-top: 16rpx;
}

.order-voucher__meta-icon {
  width: 28rpx;
  height: 28rpx;
  margin-top: 4rpx;
  flex-shrink: 0;
}

.order-voucher__meta-text {
  flex: 1;
  font-size: 26rpx;
  line-height: 1.4;
  color: #666666;
}

.order-voucher__chevron {
  flex-shrink: 0;
  font-size: 32rpx;
  line-height: 1;
  color: #cccccc;
}

.order-voucher__card--code {
  text-align: center;
}

.order-voucher__hint {
  display: block;
  margin-bottom: 32rpx;
  font-size: 26rpx;
  color: #666666;
}

.order-voucher__qr-wrap {
  position: relative;
  width: 360rpx;
  height: 360rpx;
  margin: 0 auto 28rpx;
  background: #ffffff;
  overflow: hidden;
}

.order-voucher__qr-img {
  width: 100%;
  height: 100%;
  display: block;
}

.order-voucher__qr-wrap--used .order-voucher__qr-img {
  filter: grayscale(1);
  opacity: 0.4;
}

.order-voucher__stamp {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 192rpx;
  height: 192rpx;
  margin: 0;
  border: 6rpx solid #c23a3a;
  border-radius: 50%;
  box-sizing: border-box;
  transform: translate(-50%, -50%) rotate(-22deg);
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
  box-shadow:
    inset 0 0 0 2rpx rgba(194, 58, 58, 0.55),
    0 0 0 2rpx rgba(194, 58, 58, 0.25);
  pointer-events: none;
}

.order-voucher__stamp-text {
  font-size: 36rpx;
  font-weight: 700;
  letter-spacing: 0.12em;
  color: #c23a3a;
  line-height: 1;
  white-space: nowrap;
}

.order-voucher__code {
  display: block;
  margin-bottom: 24rpx;
  font-size: 28rpx;
  color: #333333;
}

.order-voucher__warn {
  display: block;
  font-size: 24rpx;
  line-height: 1.4;
  color: #bbbbbb;
}

.order-voucher__card--detail {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.order-voucher__detail-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #222222;
}

.order-voucher__detail-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #999999;
}

.order-voucher__missing {
  padding: 96rpx 32rpx;
  text-align: center;
  color: #999999;
  font-size: 28rpx;
}

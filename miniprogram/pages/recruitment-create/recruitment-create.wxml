<view class="page recruit-publish">
  <view class="recruit-publish__chrome">
    <view class="recruit-publish__status" style="height: {{statusBarHeight}}px;"></view>
    <view class="recruit-publish__navbar" style="height: {{navBarHeight}}px;">
      <view class="recruit-publish__back" bindtap="onBack">‹</view>
      <text class="recruit-publish__nav-title">发布赛事招募</text>
    </view>
  </view>
  <view class="recruit-publish__body" style="padding-top: {{statusBarHeight + navBarHeight}}px;">
    <view class="my-recruit__tabs">
      <view
        class="my-recruit__tab {{activeTab === 'active' ? 'my-recruit__tab--active' : ''}}"
        data-tab="active"
        bindtap="onTabTap"
      >{{activeTabLabel}}</view>
      <view
        class="my-recruit__tab {{activeTab === 'ended' ? 'my-recruit__tab--active' : ''}}"
        data-tab="ended"
        bindtap="onTabTap"
      >{{endedTabLabel}}</view>
    </view>

    <view class="recruit-publish__list" wx:if="{{list.length}}">
      <event-card
        wx:for="{{list}}"
        wx:key="recruit_id"
        item="{{item}}"
        actionText="{{item.actionText}}"
        actionDisabled="{{item.actionDisabled}}"
        actionKind="{{item.actionKind}}"
        showTimeDot="{{false}}"
        bind:tap="onItemTap"
      />
    </view>
    <view class="recruit-publish__empty" wx:else>
      <view class="recruit-publish__empty-icon">
        <image src="/assets/icons/empty.png" mode="aspectFit" />
      </view>
      <text class="recruit-publish__empty-title">暂无数据</text>
    </view>
  </view>
</view>

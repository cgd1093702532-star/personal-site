.event-card {
  position: relative;
  width: 100%;
  height: 296rpx;
  border-radius: 24rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}

.event-card__bg {
  position: absolute;
  inset: 0;
}

.event-card__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.12) 0%, rgba(0, 0, 0, 0.55) 100%);
}

.event-card__top {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  right: 20rpx;
  z-index: 2;
}

.event-card__time {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  padding: 8rpx 20rpx;
  background: rgba(0, 0, 0, 0.45);
  border-radius: 999rpx;
  font-size: var(--text-caption);
  color: var(--color-text-inverse);
}

.event-card__dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #fecf13;
  flex-shrink: 0;
}

.event-card__dot--activity {
  background: #f47528;
}

.event-card__body {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: 20rpx;
  z-index: 2;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16rpx;
}

.event-card__info {
  min-width: 0;
  flex: 1;
}

.event-card__title {
  display: block;
  margin-top: 12rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text-inverse);
}

.event-card__location {
  display: block;
  margin-top: 8rpx;
  font-size: var(--text-caption);
  color: var(--color-text-inverse);
  opacity: 0.92;
}

.event-card__footer {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  flex-shrink: 0;
}

.event-card__price {
  display: flex;
  align-items: baseline;
  color: var(--color-text-inverse);
}

.event-card__price-symbol {
  font-size: var(--text-card-title);
  font-weight: 600;
}

.event-card__price-num {
  font-size: var(--text-card-title);
  font-weight: 700;
}

.event-card__price-unit {
  font-size: var(--text-micro);
  margin-left: 2rpx;
}

.event-card__btn {
  padding: 12rpx 24rpx;
  background: var(--color-text-inverse);
  border-radius: var(--radius-md);
  font-size: var(--text-card-title);
  font-weight: 600;
  color: var(--color-text-primary);
  white-space: nowrap;
}

.event-card__btn--disabled {
  background: rgba(255, 255, 255, 0.35);
  color: rgba(255, 255, 255, 0.9);
}

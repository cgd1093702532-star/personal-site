@import "../../styles/common.wxss";

.my-recruit {
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  background: var(--color-bg-subtle);
}

.my-recruit__tabs {
  display: flex;
  gap: 0;
  margin: 24rpx var(--space-page-x) 0;
  padding: 6rpx;
  background: #f0f0f0;
  border-radius: 20rpx;
  border-bottom: none;
}

.my-recruit__tab {
  flex: 1;
  padding: 16rpx 8rpx;
  text-align: center;
  font-size: 28rpx;
  line-height: 1.2;
  color: #666666;
  white-space: nowrap;
  border-radius: 16rpx;
  background: transparent;
}

.my-recruit__tab--active {
  color: #333333;
  font-weight: 600;
  background: #ffffff;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.08);
  border-bottom: none;
}

.my-recruit__overview {
  display: flex;
  gap: 16rpx;
  padding: 24rpx var(--space-page-x);
}

.my-recruit__stat-card {
  flex: 1;
  padding: 24rpx 20rpx;
  border-radius: var(--radius-md);
  border: 1rpx solid transparent;
}

.my-recruit__stat-card--signup {
  background: linear-gradient(135deg, #eef4ff 0%, #f6f9ff 100%);
  border-color: rgba(27, 87, 156, 0.12);
}

.my-recruit__stat-card--income {
  background: linear-gradient(135deg, #fff8e6 0%, #fffdf5 100%);
  border-color: rgba(254, 207, 19, 0.35);
}

.my-recruit__stat-num {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 1.2;
}

.my-recruit__stat-label {
  display: block;
  margin-top: 8rpx;
  font-size: var(--text-caption);
  color: var(--color-text-secondary);
}

.my-recruit__list {
  padding: 32rpx var(--space-page-x) 0;
}

.my-recruit__card {
  margin-bottom: 24rpx;
  padding: 28rpx 28rpx 24rpx;
  background: #ffffff;
  border-radius: 24rpx;
  border: 1rpx solid #eeeeee;
  border-left: 1rpx solid #eeeeee;
  box-shadow: none;
}

.my-recruit__card--draft {
  padding: 28rpx;
  border-left: none;
  border: 1rpx solid rgba(27, 87, 156, 0.12);
  background: linear-gradient(180deg, #eef4ff 0%, #f6f9ff 100%);
  box-shadow: none;
}

.my-recruit__meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 24rpx;
  font-size: 24rpx;
  color: #999999;
  line-height: 1.3;
}

.my-recruit__meta-id,
.my-recruit__meta-time {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.my-recruit__meta-time {
  flex-shrink: 0;
  max-width: 55%;
  text-align: right;
}

.my-recruit__body {
  display: flex;
  gap: 24rpx;
  align-items: stretch;
}

.my-recruit__cover {
  position: relative;
  flex-shrink: 0;
  width: 168rpx;
  height: 224rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #f5f5f5;
}

.my-recruit__cover-img {
  width: 100%;
  height: 100%;
  display: block;
}

.my-recruit__cover-tag {
  position: absolute;
  top: 0;
  left: 0;
  padding: 6rpx 12rpx;
  border-radius: 16rpx 0 16rpx 0;
  background: rgba(0, 0, 0, 0.72);
  color: #ffffff;
  font-size: 20rpx;
  line-height: 1.2;
}

.my-recruit__info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.my-recruit__title {
  font-size: 30rpx;
  font-weight: 600;
  color: #222222;
  line-height: 1.35;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.my-recruit__desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #888888;
  line-height: 1.45;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.my-recruit__foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: auto;
  padding-top: 16rpx;
}

.my-recruit__foot-stat {
  font-size: 24rpx;
  color: #999999;
}

.my-recruit__fee {
  font-size: 26rpx;
  font-weight: 600;
  color: #222222;
}

.my-recruit__fee--muted {
  color: #999999;
  font-weight: 500;
}

.my-recruit__actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.my-recruit__draft-head {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.my-recruit__draft-icon-wrap {
  flex-shrink: 0;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-md);
  background: rgba(255, 255, 255, 0.85);
}

.my-recruit__draft-icon {
  width: 36rpx;
  height: 36rpx;
}

.my-recruit__draft-body {
  flex: 1;
  min-width: 0;
}

.my-recruit__draft-body .my-recruit__title {
  display: block;
}

.my-recruit__draft-hint {
  display: block;
  margin-top: 6rpx;
  font-size: var(--text-caption);
  color: var(--color-text-secondary);
}

.my-recruit__draft-meta {
  padding: 16rpx 20rpx;
  border-radius: var(--radius-md);
  background: rgba(255, 255, 255, 0.72);
}

.my-recruit__draft-meta .my-recruit__row {
  margin-bottom: 6rpx;
}

.my-recruit__draft-meta .my-recruit__row:last-child {
  margin-bottom: 0;
}

.my-recruit__draft-plan {
  display: block;
  font-size: var(--text-caption);
  color: var(--color-text-body);
  line-height: 36rpx;
}

.my-recruit__actions--draft {
  margin-top: 20rpx;
}

.my-recruit__actions--draft .my-recruit__btn--primary {
  flex: 1.6;
}

.my-recruit__btn--ghost {
  background: transparent;
  color: var(--color-text-secondary);
  border: 1rpx solid rgba(27, 87, 156, 0.18);
}

.my-recruit__badge {
  flex-shrink: 0;
  padding: 4rpx 14rpx;
  border-radius: var(--radius-pill);
  font-size: var(--text-micro);
  font-weight: 500;
}

.my-recruit__badge--recruiting {
  background: rgba(254, 207, 19, 0.35);
  color: #8a6d00;
}

.my-recruit__badge--ongoing {
  background: rgba(0, 199, 119, 0.2);
  color: var(--color-course-tag);
}

.my-recruit__badge--closed,
.my-recruit__badge--ended {
  background: var(--color-bg-gray);
  color: var(--color-text-secondary);
}

.my-recruit__badge--draft {
  background: rgba(27, 87, 156, 0.1);
  color: var(--color-primary);
}

.my-recruit__row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 10rpx;
}

.my-recruit__row-icon {
  flex-shrink: 0;
  width: 28rpx;
  height: 28rpx;
  margin-top: 4rpx;
}

.my-recruit__row-text {
  font-size: var(--text-caption);
  color: var(--color-text-secondary);
  line-height: 36rpx;
}

.my-recruit__btn {
  flex: 0 0 auto;
  min-width: 0;
  height: 64rpx;
  padding: 0 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  border-radius: var(--radius-md);
  font-size: var(--text-caption);
  font-weight: 500;
}

.my-recruit__btn-icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
}

.my-recruit__btn--primary {
  flex: 0 0 auto;
  background: var(--color-primary);
  color: var(--color-text-inverse);
}

.my-recruit__btn--outline {
  background: var(--color-bg-page);
  color: var(--color-text-body);
  border: 1rpx solid var(--color-divider);
}

.my-recruit__btn--danger {
  background: rgba(244, 117, 40, 0.12);
  color: var(--color-activity);
}

.my-recruit__btn:active {
  opacity: 0.88;
}

.my-recruit__empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 48rpx 160rpx;
  text-align: center;
}

.my-recruit__empty-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 24rpx;
}

.my-recruit__empty-title {
  font-size: var(--text-section-title);
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 44rpx;
}

.my-recruit__empty-hint {
  margin-top: 12rpx;
  font-size: var(--text-caption);
  color: var(--color-text-secondary);
  line-height: 40rpx;
  max-width: 480rpx;
}

.my-recruit__empty-btn {
  margin-top: 32rpx;
  padding: 0 48rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: var(--radius-md);
  background: var(--color-primary);
  color: var(--color-text-inverse);
  font-size: var(--text-body);
  font-weight: 500;
}

.my-recruit__empty-btn:active {
  opacity: 0.88;
}

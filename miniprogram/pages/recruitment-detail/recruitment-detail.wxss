@import "../../styles/common.wxss";

.recruit-detail {
  min-height: 100vh;
  padding-bottom: 160rpx;
  background: var(--color-bg-gray);
  box-sizing: border-box;
}

.recruit-detail__chrome {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  transition: background 0.2s ease, box-shadow 0.2s ease;
}

.recruit-detail__chrome--transparent {
  background: transparent;
}

.recruit-detail__chrome--solid {
  background: var(--color-bg-page);
  box-shadow: 0 1rpx 0 var(--color-divider);
}

.recruit-detail__navbar {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.recruit-detail__back {
  position: absolute;
  left: 8rpx;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  font-weight: 300;
  color: #fff;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.35);
}

.recruit-detail__chrome--solid .recruit-detail__back {
  color: #000;
  text-shadow: none;
}

.recruit-detail__nav-title {
  max-width: 420rpx;
  font-size: 34rpx;
  font-weight: 600;
  opacity: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  transition: opacity 0.2s ease;
}

.recruit-detail__nav-title.is-visible {
  opacity: 1;
}

.recruit-detail__cover {
  width: 100%;
  overflow: hidden;
}

.recruit-detail__swiper,
.recruit-detail__cover-slide,
.recruit-detail__cover-img {
  width: 100%;
  height: 100%;
  display: block;
}

.recruit-detail__cover-slide--0 {
  background: linear-gradient(135deg, #dbe6ff 0%, #7ba3e8 100%);
}

.recruit-detail__cover-slide--1 {
  background: linear-gradient(135deg, #ffe8c8 0%, #f5a623 100%);
}

.recruit-detail__cover-slide--2 {
  background: linear-gradient(135deg, #d4f5e9 0%, #27ae60 100%);
}

.recruit-detail__body {
  position: relative;
  z-index: 2;
  margin: -56rpx var(--space-page-x) 0;
  padding: 0 0 32rpx;
  background: transparent;
  border-radius: 0;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.recruit-detail__card {
  padding: 32rpx;
  background: var(--color-bg-page);
  border-radius: 24rpx;
  box-sizing: border-box;
}

.recruit-detail__card--summary {
  border-radius: 32rpx;
}

.recruit-detail__title {
  display: block;
  margin-top: 16rpx;
  font-size: var(--text-section-title);
  font-weight: 600;
  line-height: 1.4;
  color: var(--color-text-primary);
}

.recruit-detail__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.recruit-detail__tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-sm);
  border: 1rpx solid var(--color-divider);
  background: var(--color-bg-subtle);
  font-size: 22rpx;
  line-height: 1.4;
  color: var(--color-text-secondary);
}

.recruit-detail__price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-top: 20rpx;
}

.recruit-detail__price {
  display: flex;
  align-items: baseline;
  color: var(--color-price);
  font-weight: 700;
  line-height: 1;
}

.recruit-detail__price-symbol {
  font-size: 28rpx;
  margin-right: 2rpx;
}

.recruit-detail__price-num {
  font-size: 48rpx;
}

.recruit-detail__price-dec {
  font-size: 28rpx;
}

.recruit-detail__share {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  margin: 0;
  padding: 0;
  border: none;
  background: transparent;
  line-height: 1;
}

.recruit-detail__share::after {
  border: none;
}

.recruit-detail__share--active {
  opacity: 0.7;
}

.recruit-detail__share-icon {
  width: 40rpx;
  height: 40rpx;
}

.recruit-detail__vip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 24rpx 28rpx;
  border-radius: 24rpx;
  background: #f6f0e4;
  box-sizing: border-box;
}

.recruit-detail__vip:active {
  opacity: 0.88;
}

.recruit-detail__vip-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
  flex: 1;
}

.recruit-detail__vip-icon {
  width: 44rpx;
  height: 44rpx;
  flex-shrink: 0;
}

.recruit-detail__vip-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #4a3c2c;
  line-height: 1.3;
}

.recruit-detail__vip-cta {
  flex-shrink: 0;
  font-size: 24rpx;
  color: #8a7355;
}

.recruit-detail__meta-card {
  margin-top: 0;
  padding: 28rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  background: var(--color-bg-page);
  border: none;
  border-radius: 24rpx;
  box-sizing: border-box;
}

.recruit-detail__meta-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.recruit-detail__meta-icon {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
}

.recruit-detail__meta-text {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  line-height: 1.4;
  color: var(--color-text-primary);
}

.recruit-detail__meta-arrow {
  flex-shrink: 0;
  margin-left: 8rpx;
  font-size: 36rpx;
  line-height: 1;
  color: #c8c8c8;
}

.recruit-detail__field {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 12rpx;
  padding-top: 8rpx;
}

.recruit-detail__field-label {
  flex-shrink: 0;
  width: auto;
  font-size: 28rpx;
  line-height: 1.5;
  color: var(--color-text-secondary);
  text-align: left;
}

.recruit-detail__field-value {
  flex: none;
  width: 100%;
  min-width: 0;
  font-size: 28rpx;
  line-height: 1.5;
  color: var(--color-text-primary);
  text-align: left;
}

.recruit-detail__field-value--link {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 4rpx;
}

.recruit-detail__label {
  display: block;
  margin-bottom: 12rpx;
  font-weight: 600;
  font-size: var(--text-card-title);
}

.recruit-detail__desc {
  font-size: var(--text-body);
  color: var(--color-text-body);
  line-height: 40rpx;
}

.recruit-detail__dim {
  margin-top: 32rpx;
}

.recruit-detail__dim-label {
  display: block;
  margin-bottom: 12rpx;
  font-weight: 600;
  font-size: var(--text-card-title);
}

.recruit-detail__dim-text {
  display: block;
  font-size: var(--text-body);
  color: var(--color-text-body);
  line-height: 40rpx;
}

.recruit-detail__slogan {
  margin-top: 40rpx;
  padding: 24rpx 32rpx;
  font-size: var(--text-card-title);
  font-weight: 600;
  font-style: italic;
  line-height: 44rpx;
  color: var(--color-primary);
  text-align: center;
  background: var(--color-bg-subtle);
  border-radius: var(--radius-md);
}

.recruit-detail__footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  gap: 32rpx;
  padding: 20rpx var(--space-page-x);
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: var(--color-bg-page);
  border-top: 1rpx solid var(--color-divider);
}

.recruit-detail__footer-nav {
  display: flex;
  align-items: center;
  gap: 36rpx;
  flex-shrink: 0;
}

.recruit-detail__footer-link {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  min-width: 72rpx;
  font-size: 22rpx;
  line-height: 1.2;
  color: var(--color-text-primary);
}

.recruit-detail__footer-icon {
  width: 44rpx;
  height: 44rpx;
}

.recruit-detail__btn {
  flex: 1;
  min-width: 0;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 32rpx;
  background: var(--color-primary);
  border-radius: var(--radius-md);
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
}

.recruit-detail__btn--disabled {
  background: var(--color-bg-gray);
  color: var(--color-text-secondary);
}

.recruit-modal {
  position: fixed;
  inset: 0;
  z-index: 100;
}

.recruit-modal__mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
}

.recruit-modal__panel {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 32rpx var(--space-page-x);
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  background: var(--color-bg-page);
  border-radius: var(--radius-md) var(--radius-md) 0 0;
}

.recruit-modal__title {
  display: block;
  margin-bottom: 24rpx;
  font-size: var(--text-section-title);
  font-weight: 600;
}

.recruit-modal__input {
  height: 80rpx;
  margin-bottom: 16rpx;
  padding: 0 24rpx;
  background: var(--color-bg-gray);
  border-radius: var(--radius-md);
  font-size: var(--text-body);
}

.recruit-modal__actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.recruit-modal__cancel,
.recruit-modal__submit {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: var(--radius-md);
  font-size: var(--text-card-title);
}

.recruit-modal__cancel {
  background: var(--color-bg-gray);
}

.recruit-modal__submit {
  background: var(--color-primary);
  color: var(--color-text-inverse);
}

.recruit-modal__qr {
  width: 160rpx;
  height: 160rpx;
  margin: 24rpx auto;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80rpx;
  background: var(--color-bg-subtle);
  border: 2rpx dashed var(--color-divider);
  border-radius: var(--radius-md);
}

.recruit-modal__checkin-hint {
  display: block;
  text-align: center;
  font-size: var(--text-body);
  color: var(--color-text-secondary);
  margin-bottom: 24rpx;
}

.profile-dialog {
  position: fixed;
  inset: 0;
  z-index: 2000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}

.profile-dialog__mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
}

.profile-dialog__panel {
  position: relative;
  z-index: 1;
  width: 560rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.18);
}

.profile-dialog__title {
  display: block;
  padding: 40rpx 40rpx 16rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  text-align: center;
}

.profile-dialog__body {
  display: block;
  padding: 0 40rpx 32rpx;
  font-size: 28rpx;
  line-height: 1.5;
  color: var(--color-text-body);
  text-align: center;
  word-break: break-word;
}

.profile-dialog__actions {
  display: flex;
  border-top: 1rpx solid var(--color-divider);
}

.profile-dialog__btn {
  flex: 1;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  font-size: 30rpx;
  color: var(--color-text-secondary);
}

.profile-dialog__btn + .profile-dialog__btn {
  border-left: 1rpx solid var(--color-divider);
}

.profile-dialog__btn--primary {
  color: var(--color-primary);
  font-weight: 600;
}

.profile-dialog__btn:active {
  background: var(--color-bg-subtle);
}

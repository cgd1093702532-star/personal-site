@import "../../styles/common.wxss";

.apply-submitted {
  min-height: 100vh;
  padding: 48rpx var(--space-page-x) calc(32rpx + env(safe-area-inset-bottom));
  background: var(--color-bg-subtle);
  box-sizing: border-box;
}

.apply-submitted__hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 64rpx 40rpx 48rpx;
  background: var(--color-bg-page);
  border-radius: var(--radius-md);
}

.apply-submitted__icon-wrap {
  width: 128rpx;
  height: 128rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: linear-gradient(135deg, #eef4ff 0%, #f6f9ff 100%);
  border: 4rpx solid rgba(27, 87, 156, 0.12);
}

.apply-submitted__icon {
  font-size: 56rpx;
  font-weight: 700;
  color: var(--color-primary);
  line-height: 1;
}

.apply-submitted__title {
  margin-top: 32rpx;
  font-size: var(--text-section-title);
  font-weight: 600;
  color: var(--color-text-primary);
  text-align: center;
}

.apply-submitted__desc {
  margin-top: 16rpx;
  font-size: var(--text-body);
  color: var(--color-text-secondary);
  text-align: center;
  line-height: 1.6;
}

.apply-submitted__footer {
  margin-top: 48rpx;
}

.apply-submitted__btn {
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: var(--color-primary);
  color: var(--color-text-inverse);
  border-radius: var(--radius-md);
  font-size: var(--text-card-title);
  font-weight: 600;
}

.apply-submitted__btn:active {
  opacity: 0.9;
}

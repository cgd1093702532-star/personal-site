@import "../../styles/common.wxss";

.my-student {
  min-height: 100vh;
  background: var(--color-bg-subtle);
}

.my-student__list {
  padding: 8rpx var(--space-page-x) calc(32rpx + env(safe-area-inset-bottom));
}

.my-student__item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 16rpx;
  padding: 24rpx;
  background: var(--color-bg-page);
  border-radius: var(--radius-md);
  box-shadow: 0 4rpx 16rpx rgba(27, 87, 156, 0.05);
}

.my-student__avatar {
  flex-shrink: 0;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  overflow: hidden;
}

.my-student__avatar--placeholder {
  background: var(--color-bg-gray);
}

.my-student__info {
  flex: 1;
  min-width: 0;
}

.my-student__name {
  display: block;
  font-size: var(--text-card-title);
  font-weight: 600;
  color: var(--color-text-primary);
}

.my-student__meta {
  display: block;
  margin-top: 8rpx;
  font-size: var(--text-caption);
  color: var(--color-text-secondary);
  line-height: 1.4;
}

.my-student__empty {
  padding: 120rpx 0;
  text-align: center;
  color: var(--color-text-secondary);
  font-size: var(--text-body);
}

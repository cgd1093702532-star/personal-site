.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
  height: 28rpx;
  border-radius: var(--radius-sm);
  font-size: var(--text-micro);
  line-height: 28rpx;
}

.tag--event {
  background: #fecf13;
  color: #222;
}

.tag--activity {
  background: #f47528;
  color: #fff;
}

.tag--course {
  background: #5ecf9a;
  color: #fff;
}

.tag--skill {
  background: #fff;
  color: #222;
  border: 1rpx solid #e5e8eb;
}

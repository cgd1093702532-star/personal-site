<view class="event-card" bindtap="onTap">
  <view class="event-card__bg cover-placeholder"></view>
  <view class="event-card__overlay"></view>
  <view class="event-card__top">
    <view class="event-card__time">
      <view wx:if="{{showTimeDot}}" class="event-card__dot {{item.type === 'activity' ? 'event-card__dot--activity' : ''}}"></view>
      <text>{{item.time}}</text>
    </view>
  </view>
  <view class="event-card__body">
    <view class="event-card__info">
      <category-tag
        label="{{item.typeLabel || (item.type === 'activity' ? '活动' : '赛事')}}"
        variant="{{item.type === 'activity' ? 'activity' : 'event'}}"
      />
      <text class="event-card__title">{{item.title}}</text>
      <text class="event-card__location">{{item.location}}</text>
    </view>
    <view class="event-card__footer">
      <view class="event-card__price">
        <text class="event-card__price-symbol">¥</text>
        <text class="event-card__price-num">{{item.feeDisplay || item.fee}}</text>
        <text class="event-card__price-unit">/人</text>
      </view>
      <view
        class="event-card__btn {{actionDisabled ? 'event-card__btn--disabled' : ''}}"
        catchtap="onActionTap"
      >{{actionText}}</view>
    </view>
  </view>
</view>

<view class="page recruit-publish">
  <view class="recruit-publish__chrome">
    <view class="recruit-publish__status" style="height: {{statusBarHeight}}px;"></view>
    <view class="recruit-publish__navbar" style="height: {{navBarHeight}}px;">
      <view class="recruit-publish__back" bindtap="onBack">‹</view>
      <text class="recruit-publish__nav-title">发布赛事招募</text>
    </view>
  </view>
  <view class="recruit-publish__body" style="padding-top: {{statusBarHeight + navBarHeight}}px;">
    <view class="my-recruit__tabs">
      <view
        class="my-recruit__tab {{activeTab === 'active' ? 'my-recruit__tab--active' : ''}}"
        data-tab="active"
        bindtap="onTabTap"
      >{{activeTabLabel}}</view>
      <view
        class="my-recruit__tab {{activeTab === 'ended' ? 'my-recruit__tab--active' : ''}}"
        data-tab="ended"
        bindtap="onTabTap"
      >{{endedTabLabel}}</view>
    </view>

    <view class="recruit-publish__list" wx:if="{{list.length}}">
      <event-card
        wx:for="{{list}}"
        wx:key="recruit_id"
        item="{{item}}"
        actionText="{{item.actionText}}"
        actionDisabled="{{item.actionDisabled}}"
        actionKind="{{item.actionKind}}"
        bind:tap="onItemTap"
        bind:action="onItemAction"
      />
    </view>
    <view class="recruit-publish__empty" wx:else>{{emptyText}}</view>
  </view>

  <view wx:if="{{showInitiateConfirm}}" class="profile-dialog" catchtouchmove="noop">
    <view class="profile-dialog__mask" bindtap="onCloseInitiateConfirm"></view>
    <view class="profile-dialog__panel">
      <text class="profile-dialog__title">确认发起赛事招募</text>
      <text class="profile-dialog__body">确认发起赛事招募后，在我的页>服务中心>我的招募中查看。</text>
      <view class="profile-dialog__actions">
        <view class="profile-dialog__btn" bindtap="onCloseInitiateConfirm">取消</view>
        <view class="profile-dialog__btn profile-dialog__btn--primary" bindtap="onConfirmInitiate">确认开始招募</view>
      </view>
    </view>
  </view>
</view>

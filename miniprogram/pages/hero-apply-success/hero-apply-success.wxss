@import "../../styles/common.wxss";

.hero-success-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--color-bg-subtle);
}

.hero-success-scroll {
  flex: 1;
  height: 0;
}

.hero-success {
  padding: 32rpx var(--space-page-x) 24rpx;
  background: var(--color-bg-subtle);
}

.hero-success__hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx 40rpx;
  margin-bottom: 24rpx;
  background: var(--color-bg-page);
  border-radius: var(--radius-md);
}

.hero-success__icon-wrap {
  width: 128rpx;
  height: 128rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: linear-gradient(135deg, #eef4ff 0%, #e8f5e9 100%);
  border: 4rpx solid rgba(9, 99, 63, 0.15);
  box-shadow: 0 8rpx 24rpx rgba(27, 87, 156, 0.1);
}

.hero-success__icon {
  font-size: 56rpx;
  font-weight: 700;
  color: var(--color-course-tag);
  line-height: 1;
}

.hero-success__title {
  margin-top: 28rpx;
  font-size: var(--text-section-title);
  font-weight: 600;
  color: var(--color-text-primary);
  text-align: center;
}

.hero-success__section {
  margin-bottom: 20rpx;
  padding: 28rpx;
  background: var(--color-bg-page);
  border-radius: var(--radius-md);
}

.hero-success__section-title {
  display: block;
  margin-bottom: 20rpx;
  font-size: var(--text-body);
  font-weight: 600;
  color: var(--color-text-primary);
}

.hero-success__benefits {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.hero-success__benefit {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.hero-success__check {
  flex-shrink: 0;
  width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  border-radius: 50%;
  background: rgba(9, 99, 63, 0.12);
  color: var(--color-course-tag);
  font-size: 20rpx;
  font-weight: 600;
}

.hero-success__benefit-text {
  flex: 1;
  font-size: var(--text-body);
  color: var(--color-text-body);
  line-height: 40rpx;
}

.hero-success__tips {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 20rpx;
  background: var(--color-bg-subtle);
  border-radius: var(--radius-md);
}

.hero-success__tip {
  font-size: var(--text-caption);
  color: var(--color-text-secondary);
  line-height: 36rpx;
}

.hero-success__steps {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.hero-success__step {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #eef4ff 0%, #f6f9ff 100%);
  border: 1rpx solid rgba(27, 87, 156, 0.12);
  border-radius: var(--radius-md);
}

.hero-success__step:active {
  opacity: 0.88;
}

.hero-success__step-num {
  flex-shrink: 0;
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  border-radius: 50%;
  background: var(--color-primary);
  color: var(--color-text-inverse);
  font-size: var(--text-body);
  font-weight: 600;
}

.hero-success__step-body {
  flex: 1;
  min-width: 0;
}

.hero-success__step-title {
  display: block;
  font-size: var(--text-card-title);
  font-weight: 600;
  color: var(--color-text-primary);
}

.hero-success__step-desc {
  display: block;
  margin-top: 6rpx;
  font-size: var(--text-caption);
  color: var(--color-text-secondary);
  line-height: 32rpx;
}

.hero-success__step-arrow {
  flex-shrink: 0;
  font-size: 36rpx;
  color: var(--color-text-secondary);
  line-height: 1;
}

.hero-success__footer {
  flex-shrink: 0;
  padding: 16rpx var(--space-page-x) calc(16rpx + env(safe-area-inset-bottom));
  background: var(--color-bg-subtle);
}

.hero-success__btn {
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: var(--color-primary);
  color: var(--color-text-inverse);
  border-radius: var(--radius-md);
  font-size: var(--text-card-title);
  font-weight: 600;
}

.hero-success__btn:active {
  opacity: 0.9;
}

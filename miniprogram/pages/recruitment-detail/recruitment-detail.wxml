<view class="page recruit-detail" wx:if="{{item}}">
  <view class="recruit-detail__chrome recruit-detail__chrome--{{navSolid ? 'solid' : 'transparent'}}">
    <view class="recruit-detail__status" style="height: {{statusBarHeight}}px;"></view>
    <view class="recruit-detail__navbar" style="height: {{navBarHeight}}px;">
      <view class="recruit-detail__back" bindtap="onBack">‹</view>
      <text class="recruit-detail__nav-title {{navSolid ? 'is-visible' : ''}}">{{item.title}}</text>
    </view>
  </view>

  <view class="recruit-detail__cover" style="{{coverStyle}}">
    <swiper
      wx:if="{{coverImages.length > 1}}"
      class="recruit-detail__swiper"
      circular
      autoplay
      interval="{{2000}}"
      indicator-dots
      indicator-color="rgba(255,255,255,0.45)"
      indicator-active-color="#ffffff"
    >
      <swiper-item wx:for="{{coverImages}}" wx:key="*this">
        <view class="recruit-detail__cover-slide cover-placeholder recruit-detail__cover-slide--{{index}}"></view>
      </swiper-item>
    </swiper>
    <view wx:else class="recruit-detail__cover-slide cover-placeholder recruit-detail__cover-slide--0"></view>
  </view>

  <view class="recruit-detail__body">
    <view class="recruit-detail__card recruit-detail__card--summary">
      <category-tag label="{{item.typeLabel}}" variant="{{item.type === 'event' ? 'event' : 'activity'}}" />
      <text class="recruit-detail__title">{{item.title}}</text>
      <view class="recruit-detail__tags" wx:if="{{displayTags.length}}">
        <text class="recruit-detail__tag" wx:for="{{displayTags}}" wx:key="*this">{{item}}</text>
      </view>
      <view class="recruit-detail__price-row">
        <view class="recruit-detail__price">
          <text class="recruit-detail__price-symbol">¥</text>
          <text class="recruit-detail__price-num">{{feeInt}}</text>
          <text class="recruit-detail__price-dec">.{{feeDec}}</text>
        </view>
        <button class="recruit-detail__share" bindtap="onShareTap" hover-class="recruit-detail__share--active">
          <image class="recruit-detail__share-icon" src="/assets/icons/share.png" mode="aspectFit" />
        </button>
      </view>
    </view>
    <view class="recruit-detail__vip" bindtap="onVipTap">
      <view class="recruit-detail__vip-left">
        <image class="recruit-detail__vip-icon" src="/assets/icons/vip-v.png" mode="aspectFit" />
        <text class="recruit-detail__vip-text">VIP会员卡 · 可享5大权益</text>
      </view>
      <text class="recruit-detail__vip-cta">立即尊享 ›</text>
    </view>
    <view class="recruit-detail__card recruit-detail__meta-card">
      <view class="recruit-detail__meta-row">
        <image class="recruit-detail__meta-icon" src="/assets/icons/time.png" mode="aspectFit" />
        <text class="recruit-detail__meta-text">{{item.timeDisplay}}</text>
      </view>
      <view class="recruit-detail__meta-row recruit-detail__meta-row--loc" bindtap="onLocationTap">
        <image class="recruit-detail__meta-icon" src="/assets/icons/location.png" mode="aspectFit" />
        <text class="recruit-detail__meta-text">{{item.location}}</text>
        <text class="recruit-detail__meta-arrow">›</text>
      </view>
      <view class="recruit-detail__meta-row" bindtap="onOrganizerTap">
        <image class="recruit-detail__meta-icon" src="/assets/icons/landmark.png" mode="aspectFit" />
        <text class="recruit-detail__meta-text">{{item.hero_name}}主办</text>
      </view>
      <view class="recruit-detail__field">
        <text class="recruit-detail__field-label">备注</text>
        <text class="recruit-detail__field-value">{{item.remark || '—'}}</text>
      </view>
    </view>
    <view class="recruit-detail__card recruit-detail__card--detail">
      <text class="recruit-detail__label">活动详情</text>
      <text class="recruit-detail__desc">{{item.description}}</text>
      <view class="recruit-detail__dim" wx:if="{{item.organizer_profile.credentials}}">
        <text class="recruit-detail__dim-label">专业资质与荣誉</text>
        <text class="recruit-detail__dim-text">{{item.organizer_profile.credentials}}</text>
      </view>
      <view class="recruit-detail__dim" wx:if="{{item.organizer_profile.teaching_philosophy}}">
        <text class="recruit-detail__dim-label">教学理念</text>
        <text class="recruit-detail__dim-text">{{item.organizer_profile.teaching_philosophy}}</text>
      </view>
      <view class="recruit-detail__dim" wx:if="{{item.organizer_profile.race_experience}}">
        <text class="recruit-detail__dim-label">丰富的赛事经验</text>
        <text class="recruit-detail__dim-text">{{item.organizer_profile.race_experience}}</text>
      </view>
      <view class="recruit-detail__dim" wx:if="{{item.organizer_profile.leadership_style}}">
        <text class="recruit-detail__dim-label">卓越长航领队教学特色</text>
        <text class="recruit-detail__dim-text">{{item.organizer_profile.leadership_style}}</text>
      </view>
      <view class="recruit-detail__dim" wx:if="{{item.organizer_profile.social_contribution}}">
        <text class="recruit-detail__dim-label">社会贡献</text>
        <text class="recruit-detail__dim-text">{{item.organizer_profile.social_contribution}}</text>
      </view>
      <view class="recruit-detail__slogan" wx:if="{{item.organizer_profile.slogan}}">{{item.organizer_profile.slogan}}</view>
    </view>
  </view>

  <view class="recruit-detail__footer">
    <view class="recruit-detail__footer-nav">
      <view class="recruit-detail__footer-link" bindtap="onGoHome">
        <image class="recruit-detail__footer-icon" src="/assets/icons/tab-home.png" mode="aspectFit" />
        <text>首页</text>
      </view>
      <view class="recruit-detail__footer-link" bindtap="onCustomerService">
        <image class="recruit-detail__footer-icon" src="/assets/icons/chat.png" mode="aspectFit" />
        <text>客服</text>
      </view>
    </view>
    <view class="recruit-detail__btn {{footerDisabled ? 'recruit-detail__btn--disabled' : ''}}" bindtap="onFooterTap">{{footerLabel}}</view>
  </view>
</view>

<view wx:if="{{showCheckin}}" class="recruit-modal">
  <view class="recruit-modal__mask" bindtap="onCloseCheckin"></view>
  <view class="recruit-modal__panel recruit-modal__panel--checkin">
    <text class="recruit-modal__title">签到二维码</text>
    <view class="recruit-modal__qr">▦</view>
    <text class="recruit-modal__checkin-hint">请向工作人员出示此码完成核销</text>
    <view class="recruit-modal__actions">
      <view class="recruit-modal__cancel" bindtap="onCloseCheckin">关闭</view>
      <view class="recruit-modal__submit" bindtap="onConfirmCheckin">模拟核销</view>
    </view>
  </view>
</view>

<view wx:if="{{showForm}}" class="recruit-modal">
  <view class="recruit-modal__mask" bindtap="onCloseForm"></view>
  <view class="recruit-modal__panel">
    <text class="recruit-modal__title">填写报名信息</text>
    <input class="recruit-modal__input" placeholder="联系人姓名" data-field="name" value="{{form.name}}" bindinput="onInput" />
    <input class="recruit-modal__input" placeholder="联系电话" type="number" maxlength="11" data-field="phone" value="{{form.phone}}" bindinput="onInput" />
    <input class="recruit-modal__input" placeholder="备注（选填）" data-field="remark" value="{{form.remark}}" bindinput="onInput" />
    <view class="recruit-modal__actions">
      <view class="recruit-modal__cancel" bindtap="onCloseForm">取消</view>
      <view class="recruit-modal__submit" bindtap="onSubmit">提交</view>
    </view>
  </view>
</view>

<view wx:if="{{showInitiateConfirm}}" class="profile-dialog" catchtouchmove="noop">
  <view class="profile-dialog__mask" bindtap="onCloseInitiateConfirm"></view>
  <view class="profile-dialog__panel">
    <text class="profile-dialog__title">确认发起赛事招募</text>
    <text class="profile-dialog__body">确认发起赛事招募后，在我的页>服务中心>我的活动赛事中查看。</text>
    <view class="profile-dialog__actions">
      <view class="profile-dialog__btn" bindtap="onCloseInitiateConfirm">取消</view>
      <view class="profile-dialog__btn profile-dialog__btn--primary" bindtap="onConfirmInitiate">确认开始招募</view>
    </view>
  </view>
</view>

<view wx:if="{{showInitiateSuccess}}" class="recruit-success-sheet" catchtouchmove="noop">
  <view class="recruit-success-sheet__mask" bindtap="onCloseInitiateSuccess"></view>
  <view class="recruit-success-sheet__panel">
    <text class="recruit-success-sheet__body">已成功发起招募，快去看看吧，邀请更多队友的加入</text>
    <view class="recruit-success-sheet__item" bindtap="onViewMyRecruitments">去查看</view>
    <view class="recruit-success-sheet__item recruit-success-sheet__item--cancel" bindtap="onCloseInitiateSuccess">取消</view>
  </view>
</view>

<hero-share
  visible="{{shareVisible}}"
  hero="{{shareHero}}"
  heroId="{{recruitId}}"
  bind:close="onShareClose"
/>

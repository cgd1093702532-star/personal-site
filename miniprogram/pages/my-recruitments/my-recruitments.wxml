<view class="page my-recruit">
  <view class="my-recruit__tabs">
    <view class="my-recruit__tabs-track">
      <view
        wx:for="{{tabs}}"
        wx:key="key"
        class="my-recruit__tab {{activeTab === item.key ? 'my-recruit__tab--active' : ''}}"
        data-key="{{item.key}}"
        bindtap="onTabChange"
      >{{item.display}}</view>
    </view>
  </view>

  <view class="my-recruit__toolbar" wx:if="{{showFilterToolbar}}">
    <view class="my-recruit__filter {{onlyMine ? 'my-recruit__filter--on' : ''}}" bindtap="onToggleOnlyMine">
      <view class="my-recruit__filter-box">
        <image wx:if="{{onlyMine}}" class="my-recruit__filter-check" src="/assets/icons/check-primary.png" mode="aspectFit" />
      </view>
      <text class="my-recruit__filter-label">仅显示我发起的</text>
    </view>
  </view>

  <view class="my-recruit__list">
    <block wx:for="{{currentList}}" wx:key="recruit_id">
      <view wx:if="{{item.actionType === 'draft'}}" class="my-recruit__card my-recruit__card--draft">
        <text class="my-recruit__relation">{{item.relationLabel}}</text>
        <view class="my-recruit__draft-head">
          <view class="my-recruit__draft-icon-wrap">
            <image class="my-recruit__draft-icon" src="/assets/icons/edit.png" mode="aspectFit" />
          </view>
          <view class="my-recruit__draft-body">
            <text class="my-recruit__title">{{item.title}}</text>
            <text class="my-recruit__draft-hint">未发布 · 信息待完善</text>
          </view>
          <text class="my-recruit__badge my-recruit__badge--draft">{{item.badgeLabel}}</text>
        </view>
        <view class="my-recruit__draft-meta">
          <view class="my-recruit__row" wx:if="{{item.location}}">
            <image class="my-recruit__row-icon" src="/assets/icons/location.png" mode="aspectFit" />
            <text class="my-recruit__row-text">{{item.location}}</text>
          </view>
          <text class="my-recruit__draft-plan">计划招募 {{item.total}} 人 · ¥{{item.fee}}/人</text>
        </view>
        <view class="my-recruit__actions my-recruit__actions--draft">
          <view class="my-recruit__btn my-recruit__btn--primary" data-id="{{item.recruit_id}}" bindtap="onEditDraft">继续编辑</view>
          <view class="my-recruit__btn my-recruit__btn--ghost" data-id="{{item.recruit_id}}" data-title="{{item.title}}" bindtap="onDeleteDraft">删除</view>
        </view>
      </view>

      <view wx:else class="my-recruit__card {{item.listTab === 'ended' || item.displayStatus === 'ended' ? 'my-recruit__card--ended' : ''}}" data-id="{{item.recruit_id}}" bindtap="onViewDetail">
        <text class="my-recruit__relation">{{item.relationLabel}}</text>
        <view class="my-recruit__main">
          <view class="my-recruit__cover">
            <image class="my-recruit__cover-img" src="{{item.coverSrc}}" mode="aspectFill" />
          </view>
          <view class="my-recruit__info">
            <view class="my-recruit__info-top">
              <text class="my-recruit__title">{{item.title}}</text>
              <text class="my-recruit__type-tag my-recruit__type-tag--{{item.type}}">{{item.typeLabel}}</text>
            </view>
            <text class="my-recruit__time">{{item.timeDisplay}}</text>
            <text class="my-recruit__place">{{item.placeLabel}}：{{item.location || '地点待定'}}</text>
            <text class="my-recruit__fee {{item.listTab === 'ended' || item.displayStatus === 'ended' ? 'my-recruit__fee--muted' : ''}}">¥{{item.fee}}/人</text>
          </view>
        </view>

        <view class="my-recruit__bar">
          <text class="my-recruit__quota">{{item.quotaText}}</text>
          <view class="my-recruit__actions" wx:if="{{item.canViewSignup && (item.actionType === 'active' || item.actionType === 'closed')}}">
            <view class="my-recruit__btn my-recruit__btn--primary" data-title="{{item.title}}" data-signed="{{item.signed}}" data-id="{{item.recruit_id}}" catchtap="onViewSignup">已报名人员</view>
          </view>
        </view>
      </view>
    </block>

    <view wx:if="{{currentList.length === 0}}" class="my-recruit__empty">
      <image class="my-recruit__empty-icon" src="{{emptyState.icon}}" mode="aspectFit" />
      <text class="my-recruit__empty-title">{{emptyState.title}}</text>
      <text class="my-recruit__empty-hint">{{emptyState.hint}}</text>
      <view
        wx:if="{{emptyState.actionText}}"
        class="my-recruit__empty-btn"
        bindtap="onEmptyAction"
      >{{emptyState.actionText}}</view>
    </view>
  </view>
</view>

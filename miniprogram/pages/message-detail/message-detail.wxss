@import "../../styles/common.wxss";

.msg-detail {
  min-height: 100vh;
  padding: 24rpx 32rpx calc(48rpx + env(safe-area-inset-bottom));
  background: #f5f5f5;
  box-sizing: border-box;
}

.msg-detail__item {
  margin-bottom: 24rpx;
  padding: 32rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.msg-detail__item:last-child {
  margin-bottom: 0;
}

.msg-detail__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.msg-detail__title {
  flex: 1;
  min-width: 0;
  font-size: 32rpx;
  font-weight: 600;
  color: #222;
  line-height: 1.4;
}

.msg-detail__time {
  flex-shrink: 0;
  font-size: 24rpx;
  color: #999;
  line-height: 1.4;
}

.msg-detail__content {
  display: block;
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #666;
  line-height: 1.55;
}

.msg-detail__empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 70vh;
  padding: 160rpx 48rpx;
  box-sizing: border-box;
}

.msg-detail__empty-icon {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.msg-detail__empty-icon image {
  width: 72rpx;
  height: 72rpx;
  display: block;
}

.msg-detail__empty-title {
  margin-top: 24rpx;
  font-size: 30rpx;
  font-weight: 500;
  color: #999;
}

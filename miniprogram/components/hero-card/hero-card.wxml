<view class="hero-card hero-card--{{layout}}">
  <view class="hero-card__head" bindtap="onHeadTap">
    <view class="hero-card__avatar cover-placeholder"></view>
    <view class="hero-card__meta">
      <view class="hero-card__name-row">
        <text class="hero-card__name">{{displayName}}</text>
        <view class="hero-card__tags">
          <category-tag wx:for="{{displayTypes}}" wx:key="*this" label="{{item}}" variant="skill" />
        </view>
      </view>
      <view class="hero-card__honors" wx:if="{{honorItems.length}}">
        <view
          class="hero-card__honor {{item.primary ? 'hero-card__honor--primary' : 'hero-card__honor--secondary'}}"
          wx:for="{{honorItems}}"
          wx:key="text"
        >
          <view wx:if="{{item.primary}}" class="hero-card__honor-icon">
            <image class="hero-card__honor-icon-img" src="/assets/icons/crown.png" mode="aspectFit" />
          </view>
          <text class="hero-card__honor-text">{{item.text}}</text>
        </view>
      </view>
    </view>
  </view>
  <view class="hero-card__rows" wx:if="{{displayRows.length}}">
    <view
      class="hero-card__row"
      wx:for="{{displayRows}}"
      wx:key="key"
      catchtap="onRowTap"
      data-type="{{item.type}}"
      data-target-id="{{item.target_id}}"
    >
      <category-tag
        label="{{item.tagLabel}}"
        variant="{{item.tagVariant}}"
      />
      <text class="hero-card__row-text">{{item.text}}</text>
      <text class="hero-card__row-arrow">›</text>
    </view>
  </view>
</view>

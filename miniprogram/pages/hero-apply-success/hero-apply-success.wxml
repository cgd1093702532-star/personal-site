<view class="page hero-success-page">
  <scroll-view class="hero-success-scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="hero-success">
      <view class="hero-success__hero">
        <view class="hero-success__icon-wrap">
          <text class="hero-success__icon">✓</text>
        </view>
        <text class="hero-success__title">恭喜您！成功认证英雄</text>
      </view>

      <view class="hero-success__section">
        <text class="hero-success__section-title">🎁 您已获得的认证权益</text>
        <view class="hero-success__benefits">
          <view class="hero-success__benefit" wx:for="{{benefits}}" wx:key="*this">
            <text class="hero-success__check">✓</text>
            <text class="hero-success__benefit-text">{{item}}</text>
          </view>
        </view>
      </view>

      <view class="hero-success__section">
        <text class="hero-success__section-title">📌 温馨提示</text>
        <view class="hero-success__tips">
          <text class="hero-success__tip" wx:for="{{tips}}" wx:key="*this">· {{item}}</text>
        </view>
      </view>

      <view class="hero-success__section">
        <text class="hero-success__section-title">接下来，建议您完成</text>
        <view class="hero-success__steps">
          <view class="hero-success__step" bindtap="onGoProfile">
            <view class="hero-success__step-num">1</view>
            <view class="hero-success__step-body">
              <text class="hero-success__step-title">完善英雄资料</text>
              <text class="hero-success__step-desc">补充简介、荣誉与资质证书</text>
            </view>
            <text class="hero-success__step-arrow">›</text>
          </view>
          <view class="hero-success__step" bindtap="onGoRecruit">
            <view class="hero-success__step-num">2</view>
            <view class="hero-success__step-body">
              <text class="hero-success__step-title">发布首个赛事招募</text>
              <text class="hero-success__step-desc">开启您的第一场水上活动招募</text>
            </view>
            <text class="hero-success__step-arrow">›</text>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="hero-success__footer">
    <view class="hero-success__btn" bindtap="onBackProfile">返回个人中心</view>
  </view>
</view>

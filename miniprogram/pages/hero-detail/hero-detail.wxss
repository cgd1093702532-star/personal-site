@import "../../styles/common.wxss";

.hero-detail {
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

.hero-detail--missing {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.hero-detail-missing {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48rpx 64rpx 28vh;
  text-align: center;
  box-sizing: border-box;
}

.hero-detail-missing__icon {
  width: 144rpx;
  height: 144rpx;
  margin-bottom: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: var(--color-bg-gray);
}

.hero-detail-missing__icon-img {
  width: 80rpx;
  height: 80rpx;
  opacity: 0.72;
}

.hero-detail-missing__title {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 48rpx;
}

.hero-detail-missing__hint {
  display: block;
  margin-top: 16rpx;
  max-width: 520rpx;
  font-size: 26rpx;
  line-height: 40rpx;
  color: var(--color-text-secondary);
}

.hero-detail__bottom-spacer {
  height: 48rpx;
}

.hero-detail__bottom-spacer--cta {
  height: calc(140rpx + env(safe-area-inset-bottom));
}

.hero-detail__footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx var(--space-page-x);
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: var(--color-bg-page);
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
  z-index: 20;
  box-sizing: border-box;
}

.hero-detail__apply-btn {
  flex: 1;
  min-width: 0;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 32rpx;
  text-align: center;
  background: var(--color-accent);
  border-radius: var(--radius-md);
  font-size: var(--text-card-title);
  font-weight: 600;
  color: var(--color-text-primary);
  box-sizing: border-box;
}

.hero-detail__footer--share-only .hero-detail__share {
  flex: 1;
}
.hero-profile {
  position: relative;
  padding-top: 200rpx;
  margin-bottom: 8rpx;
}

.hero-profile__cover {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  z-index: 0;
  height: 200rpx;
  background: linear-gradient(135deg, #dbe6ff 0%, #a8c4f5 55%, #7ba3e8 100%);
}

.hero-detail__share {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  flex-shrink: 0;
  min-width: 144rpx;
  height: 88rpx;
  padding: 0 28rpx;
  border-radius: var(--radius-md);
  border: 2rpx solid var(--color-primary);
  background: #fff;
  box-sizing: border-box;
}

.hero-detail__share:active {
  opacity: 0.85;
}

.hero-detail__share-icon {
  font-size: 28rpx;
  color: var(--color-primary);
}

.hero-detail__share-text {
  font-size: 28rpx;
  color: var(--color-primary);
  font-weight: 500;
}

.hero-profile__main {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: -72rpx;
  padding: 0 var(--space-page-x) 32rpx;
}

.hero-profile__avatar {
  position: relative;
  z-index: 3;
  width: 144rpx;
  height: 144rpx;
  border-radius: 50%;
  border: 6rpx solid var(--color-bg-page);
  box-shadow: 0 8rpx 24rpx rgba(27, 87, 156, 0.15);
}

.hero-profile__name {
  margin-top: 20rpx;
  font-size: 40rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.hero-profile__subtitle {
  margin-top: 8rpx;
  font-size: var(--text-caption);
  color: var(--color-text-secondary);
}

.hero-profile__rating {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 16rpx;
}

.hero-profile__stars {
  display: flex;
  gap: 4rpx;
}

.hero-profile__star {
  font-size: 28rpx;
  color: #e0e0e0;
  line-height: 1;
}

.hero-profile__star--filled {
  color: var(--color-accent);
}

.hero-profile__star--half {
  color: var(--color-accent);
  opacity: 0.55;
}

.hero-profile__score {
  font-size: var(--text-body);
  font-weight: 600;
  color: var(--color-activity);
}

.hero-profile__tags {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 10rpx;
  margin-top: 20rpx;
  max-width: 100%;
}

.hero-profile__tag {
  padding: 6rpx 16rpx;
  border-radius: var(--radius-pill);
  background: var(--color-activity-bg);
  font-size: var(--text-micro);
  color: var(--color-text-body);
}

.hero-profile__stats {
  display: flex;
  width: 100%;
  margin-top: 32rpx;
  padding: 24rpx 0;
  background: var(--color-bg-subtle);
  border-radius: var(--radius-md);
}

.hero-profile__stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.hero-profile__stat-num {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.hero-profile__stat-num--text {
  font-size: 24rpx;
  line-height: 1.25;
  font-weight: 600;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  word-break: break-all;
}

.hero-profile__stat-label {
  font-size: var(--text-micro);
  color: var(--color-text-secondary);
}

.hero-detail__block {
  margin-top: 32rpx;
  padding: 0 var(--space-page-x);
}

.hero-detail__label {
  display: block;
  margin-bottom: 16rpx;
  font-size: var(--text-section-title);
  font-weight: 600;
  color: var(--color-text-primary);
}

.hero-detail__bio {
  font-size: var(--text-body);
  color: var(--color-text-body);
  line-height: 44rpx;
  white-space: pre-wrap;
}

.hero-detail__honor {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--color-divider);
}

.hero-detail__honor:last-child {
  border-bottom: none;
}

.hero-detail__honor-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  background: #f2f4f7;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.hero-detail__honor-icon-img {
  width: 40rpx;
  height: 40rpx;
}

.hero-detail__honor-body {
  flex: 1;
  min-width: 0;
}

.hero-detail__honor-name {
  display: block;
  font-size: var(--text-card-title);
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 1.35;
}

.hero-detail__honor-summary {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 8rpx;
  line-height: 1.35;
}

.hero-detail__gallery {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.hero-detail__gallery-item {
  width: calc((100% - 24rpx) / 3);
  height: 200rpx;
  border-radius: var(--radius-md);
}

.hero-detail__cert-scroll {
  white-space: nowrap;
  width: 100%;
}

.hero-detail__cert-card {
  display: inline-flex;
  flex-direction: column;
  width: 200rpx;
  margin-right: 16rpx;
  vertical-align: top;
}

.hero-detail__cert-card:last-child {
  margin-right: 0;
}

.hero-detail__cert-img {
  width: 200rpx;
  height: 140rpx;
  border-radius: var(--radius-md);
}

.hero-detail__cert-name {
  display: block;
  margin-top: 10rpx;
  font-size: var(--text-caption);
  color: var(--color-text-body);
  text-align: center;
  white-space: normal;
  line-height: 32rpx;
}

.hero-teaching {
  padding: 28rpx 24rpx;
  border-radius: 24rpx;
  background: #eaf3ff;
  box-sizing: border-box;
}

.hero-cert {
  padding: 28rpx 24rpx;
  border-radius: 24rpx;
  background: #eef2f7;
  box-sizing: border-box;
}

.hero-cert__head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.hero-cert__icon {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
}

.hero-cert__title {
  font-size: var(--text-card-title);
  font-weight: 700;
  color: var(--color-text-primary);
}

.hero-teaching__head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.hero-teaching__icon {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
}

.hero-teaching__title {
  font-size: var(--text-card-title);
  font-weight: 700;
  color: var(--color-text-primary);
}

.hero-teaching__intro {
  display: block;
  font-size: var(--text-body);
  line-height: 1.6;
  color: var(--color-text-body);
}

.hero-teaching__lead {
  display: block;
  margin: 20rpx 0 16rpx;
  font-size: var(--text-body);
  font-weight: 600;
  color: var(--color-text-primary);
}

.hero-teaching__item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 24rpx;
  margin-bottom: 12rpx;
  background: #fff;
  border-radius: 999rpx;
  box-shadow: 0 2rpx 8rpx rgba(27, 87, 156, 0.06);
}

.hero-teaching__item:last-child {
  margin-bottom: 0;
}

.hero-teaching__item-title {
  flex-shrink: 0;
  font-size: var(--text-body);
  font-weight: 700;
  color: var(--color-text-primary);
  white-space: nowrap;
}

.hero-teaching__item-desc {
  flex: 1;
  min-width: 0;
  font-size: var(--text-caption);
  color: var(--color-text-body);
  line-height: 1.4;
}

.hero-race {
  padding: 28rpx 24rpx;
  border-radius: 24rpx;
  background: #fff0e6;
  box-sizing: border-box;
}

.hero-race__head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.hero-race__icon {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
}

.hero-race__title {
  font-size: var(--text-card-title);
  font-weight: 700;
  color: var(--color-text-primary);
}

.hero-race__intro {
  display: block;
  margin-bottom: 20rpx;
  font-size: var(--text-body);
  line-height: 1.6;
  color: var(--color-text-body);
}

.hero-race__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.hero-race__grid-item {
  width: 100%;
  aspect-ratio: 1;
  border-radius: var(--radius-md);
  overflow: hidden;
}

.hero-race__grid-img {
  width: 100%;
  height: 100%;
}

.hero-race__item {
  position: relative;
  height: 112rpx;
  margin-bottom: 16rpx;
  border-radius: 20rpx;
  overflow: hidden;
  background: #fff;
  box-shadow: 0 2rpx 8rpx rgba(196, 92, 18, 0.08);
}

.hero-race__item:last-child {
  margin-bottom: 0;
}

.hero-race__label {
  position: absolute;
  z-index: 1;
  top: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  font-size: var(--text-body);
  font-weight: 600;
  color: var(--color-text-primary);
  box-sizing: border-box;
}

.hero-race__item--photo-right .hero-race__label {
  left: 0;
  right: 40%;
  padding: 0 28rpx;
}

.hero-race__item--photo-left .hero-race__label {
  left: 40%;
  right: 0;
  justify-content: flex-end;
  padding: 0 28rpx;
}

.hero-race__media {
  position: absolute;
  top: 0;
  bottom: 0;
  width: 58%;
}

.hero-race__item--photo-right .hero-race__media {
  right: 0;
  clip-path: polygon(18% 0, 100% 0, 100% 100%, 0 100%);
}

.hero-race__item--photo-left .hero-race__media {
  left: 0;
  clip-path: polygon(0 0, 100% 0, 82% 100%, 0 100%);
}

.hero-race__media--0 {
  background: linear-gradient(135deg, #7eb8e8, #3a6ea5);
}

.hero-race__media--1 {
  background: linear-gradient(135deg, #f0c27a, #c47a2c);
}

.hero-race__media--2 {
  background: linear-gradient(135deg, #8ec5a3, #3d8a6a);
}

.hero-voyage {
  padding: 28rpx 24rpx;
  border-radius: 24rpx;
  background: #f5f1ea;
  box-sizing: border-box;
}

.hero-voyage__head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.hero-voyage__icon {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
}

.hero-voyage__title {
  font-size: var(--text-card-title);
  font-weight: 700;
  color: var(--color-text-primary);
}

.hero-voyage__intro {
  display: block;
  margin-bottom: 20rpx;
  font-size: var(--text-body);
  line-height: 1.6;
  color: var(--color-text-body);
}

.hero-voyage__grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.hero-voyage__card {
  overflow: hidden;
  border-radius: 16rpx;
  background: #fff;
}

.hero-voyage__photo {
  width: 100%;
  aspect-ratio: 4 / 3;
}

.hero-voyage__photo--0 {
  background: linear-gradient(135deg, #7eb8e8, #3a6ea5);
}

.hero-voyage__photo--1 {
  background: linear-gradient(135deg, #f0c27a, #c47a2c);
}

.hero-voyage__photo--2 {
  background: linear-gradient(135deg, #8ec5a3, #3d8a6a);
}

.hero-voyage__photo--3 {
  background: linear-gradient(135deg, #9bb4d0, #4a678a);
}

.hero-voyage__caption {
  display: block;
  padding: 16rpx 12rpx;
  font-size: var(--text-caption);
  font-weight: 500;
  color: var(--color-text-primary);
  text-align: center;
  line-height: 1.4;
}

.hero-social {
  padding: 28rpx 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #fff3e8 0%, #fffaf6 100%);
  box-sizing: border-box;
}

.hero-social__head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.hero-social__badge {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #f47528;
  color: #fff;
  font-size: 20rpx;
  line-height: 36rpx;
  text-align: center;
  flex-shrink: 0;
}

.hero-social__title {
  font-size: var(--text-card-title);
  font-weight: 700;
  color: var(--color-text-primary);
}

.hero-social__intro {
  display: block;
  margin-bottom: 20rpx;
  font-size: var(--text-body);
  line-height: 1.6;
  color: var(--color-text-body);
}

.hero-social__item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 12rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(244, 117, 40, 0.06);
}

.hero-social__item:last-child {
  margin-bottom: 0;
}

.hero-social__dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #f47528;
  flex-shrink: 0;
}

.hero-social__text {
  flex: 1;
  min-width: 0;
  font-size: var(--text-body);
  font-weight: 500;
  color: var(--color-text-primary);
  line-height: 1.4;
}

.hero-detail__label-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.hero-detail__label-extra {
  font-size: var(--text-caption);
  color: var(--color-text-secondary);
}

.hero-detail__recruit-list,
.hero-detail__course-list {
  width: 100%;
}

.hero-detail__activity-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  background: var(--color-bg-subtle);
  border-radius: var(--radius-md);
}

.hero-detail__activity-card:last-of-type {
  margin-bottom: 0;
}

.hero-detail__activity-card:active {
  opacity: 0.88;
}

.hero-detail__activity-main {
  display: flex;
  gap: 24rpx;
  align-items: flex-start;
}

.hero-detail__activity-thumb {
  width: 176rpx;
  height: 176rpx;
  border-radius: var(--radius-md);
  flex-shrink: 0;
  overflow: hidden;
}

.hero-detail__activity-thumb--0 {
  background: linear-gradient(135deg, #c8e4ff 0%, #5a9fd4 100%);
}

.hero-detail__activity-thumb--1 {
  background: linear-gradient(135deg, #ffe8c8 0%, #f5a623 100%);
}

.hero-detail__activity-thumb--2 {
  background: linear-gradient(135deg, #d4f5e9 0%, #27ae60 100%);
}

.hero-detail__activity-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.hero-detail__activity-title-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.hero-detail__activity-title {
  flex: 1;
  min-width: 0;
  font-size: var(--text-card-title);
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 44rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hero-detail__activity-meta {
  display: block;
  margin-top: 8rpx;
  font-size: var(--text-caption);
  color: var(--color-text-secondary);
  line-height: 36rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hero-detail__activity-fee {
  display: block;
  margin-top: 12rpx;
  font-size: var(--text-body);
  font-weight: 600;
  color: var(--color-price);
}

.hero-detail__activity-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  width: 100%;
}

.hero-detail__activity-signup {
  flex: 1;
  min-width: 0;
  font-size: var(--text-caption);
  color: var(--color-text-secondary);
  text-align: left;
  line-height: 36rpx;
}

.hero-detail__activity-btn {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 28rpx;
  border-radius: 12rpx;
  background: var(--color-primary);
  color: #fff;
  font-size: var(--text-caption);
  font-weight: 500;
  line-height: 1;
}

.hero-detail__recruit-expand {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  padding: 24rpx 0;
  font-size: var(--text-caption);
  color: var(--color-text-secondary);
}

.hero-detail__recruit-expand:active {
  opacity: 0.7;
}

.hero-detail__recruit-title {
  display: block;
  font-size: var(--text-card-title);
  font-weight: 600;
  color: var(--color-text-primary);
}

.hero-detail__recruit-meta {
  display: block;
  margin-top: 8rpx;
  font-size: var(--text-caption);
  color: var(--color-text-secondary);
  line-height: 36rpx;
}

.hero-detail__recruit-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
}

.hero-detail__recruit-fee {
  flex-shrink: 0;
  font-size: var(--text-body);
  font-weight: 600;
  color: var(--color-price);
}

.hero-detail__recruit-signup {
  flex-shrink: 1;
  min-width: 0;
  font-size: var(--text-caption);
  color: var(--color-text-secondary);
  text-align: right;
}

.hero-detail__course-card {
  display: flex;
  gap: 24rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  background: var(--color-bg-subtle);
  border-radius: var(--radius-md);
}

.hero-detail__course-card:last-child {
  margin-bottom: 0;
}

.hero-detail__course-card:active {
  opacity: 0.88;
}

.hero-detail__course-thumb {
  width: 144rpx;
  height: 144rpx;
  border-radius: var(--radius-md);
  flex-shrink: 0;
  overflow: hidden;
}

.hero-detail__course-thumb--0 {
  background: linear-gradient(135deg, #dbe6ff 0%, #7ba3e8 100%);
}

.hero-detail__course-thumb--1 {
  background: linear-gradient(135deg, #ffe8c8 0%, #f5a623 100%);
}

.hero-detail__course-thumb--2 {
  background: linear-gradient(135deg, #d4f5e9 0%, #27ae60 100%);
}

.hero-detail__course-body {
  flex: 1;
  min-width: 0;
}

.hero-detail__course-body .hero-detail__recruit-bottom {
  margin-top: 8rpx;
}

.profile-dialog {
  position: fixed;
  inset: 0;
  z-index: 2000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}

.profile-dialog__mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
}

.profile-dialog__panel {
  position: relative;
  z-index: 1;
  width: 560rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.18);
}

.profile-dialog__title {
  display: block;
  padding: 40rpx 40rpx 16rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  text-align: center;
}

.profile-dialog__body {
  display: block;
  padding: 0 40rpx 32rpx;
  font-size: 28rpx;
  line-height: 1.5;
  color: var(--color-text-body);
  text-align: center;
  word-break: break-word;
}

.profile-dialog__actions {
  display: flex;
  border-top: 1rpx solid var(--color-divider);
}

.profile-dialog__btn {
  flex: 1;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  font-size: 30rpx;
  color: var(--color-text-secondary);
}

.profile-dialog__btn + .profile-dialog__btn {
  border-left: 1rpx solid var(--color-divider);
}

.profile-dialog__btn--primary {
  color: var(--color-primary);
  font-weight: 600;
}

.profile-dialog__btn--cancel {
  color: var(--color-text-secondary);
}

.profile-dialog__btn:active {
  background: var(--color-bg-subtle);
}

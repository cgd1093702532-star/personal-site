.hero-card {
  display: block;
  flex-shrink: 0;
  width: 528rpx;
  padding: 24rpx;
  margin-right: 16rpx;
  border-radius: var(--radius-md);
  background: linear-gradient(180deg, #dbe6ff 0%, #f6f9ff 100%);
  box-sizing: border-box;
}

.hero-card--list {
  display: block;
  width: 100%;
  margin-right: 0;
  margin-bottom: 16rpx;
}

.hero-card--list:last-child {
  margin-bottom: 0;
}

.hero-card__head {
  display: flex;
  gap: 16rpx;
}

.hero-card__avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--radius-md);
  flex-shrink: 0;
}

.hero-card__meta {
  flex: 1;
  min-width: 0;
}

.hero-card__name-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
}

.hero-card__name {
  font-size: var(--text-card-title);
  font-weight: 600;
  color: var(--color-text-primary);
}

.hero-card__tags {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.hero-card__tags .tag--skill {
  border: 1rpx solid var(--color-divider);
}

.hero-card__honors {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}

.hero-card__honor {
  display: inline-flex;
  align-items: center;
  max-width: 100%;
  height: 32rpx;
  border-radius: var(--radius-sm);
  overflow: hidden;
}

.hero-card__honor--primary {
  background: var(--color-activity-bg);
}

.hero-card__honor-icon {
  width: 32rpx;
  height: 32rpx;
  background: var(--color-activity);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  flex-shrink: 0;
}

.hero-card__honor-text {
  padding: 0 10rpx;
  font-size: var(--text-micro);
  color: var(--color-text-body);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hero-card__honor--secondary {
  padding: 0 10rpx;
  background: #fff5eb;
}

.hero-card__honor--secondary .hero-card__honor-text {
  color: var(--color-text-secondary);
}

.hero-card__rows {
  margin-top: 16rpx;
}

.hero-card__row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  height: 64rpx;
  padding: 0 16rpx;
  margin-bottom: 8rpx;
  background: var(--color-overlay-card);
  border-radius: var(--radius-md);
}

.hero-card__row:active {
  opacity: 0.85;
}

.hero-card__row:last-child {
  margin-bottom: 0;
}

.hero-card__row-text {
  flex: 1;
  font-size: var(--text-body);
  font-weight: 500;
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hero-card__row-arrow {
  color: var(--color-text-secondary);
  font-size: 28rpx;
  flex-shrink: 0;
}

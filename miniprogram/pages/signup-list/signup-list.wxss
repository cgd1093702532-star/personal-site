@import "../../styles/common.wxss";

.signup-member {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding: 24rpx var(--space-page-x) 48rpx;
  background: var(--color-bg-subtle);
  box-sizing: border-box;
}

.signup-member--empty-page {
  min-height: 100vh;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

.signup-member__list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.signup-member__item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 24rpx;
  background: var(--color-bg-page);
  border-radius: var(--radius-md);
  box-shadow: 0 4rpx 16rpx rgba(27, 87, 156, 0.05);
}

.signup-member__avatar {
  flex-shrink: 0;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--color-bg-gray);
}

.signup-member__body {
  flex: 1;
  min-width: 0;
  padding-right: 12rpx;
}

.signup-member__name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 1.4;
}

.signup-member__phone {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
  color: var(--color-text-body);
}

.signup-member__time {
  flex-shrink: 0;
  max-width: 42%;
  margin: 0;
  font-size: 22rpx;
  line-height: 1.35;
  color: var(--color-text-secondary);
  text-align: right;
}

.signup-member__status {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.signup-member__confirm {
  flex-shrink: 0;
  padding: 12rpx 28rpx;
  background: var(--color-primary);
  color: var(--color-text-inverse);
  border-radius: var(--radius-pill);
  font-size: 26rpx;
  font-weight: 600;
}

.signup-member__empty {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  padding: 80rpx 48rpx 160rpx;
  text-align: center;
  box-sizing: border-box;
}

.signup-member__empty-icon {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.signup-member__empty-icon image {
  width: 72rpx;
  height: 72rpx;
  display: block;
}

.signup-member__empty-title {
  margin-top: 24rpx;
  font-size: 30rpx;
  font-weight: 500;
  color: #999999;
  line-height: 1.4;
}

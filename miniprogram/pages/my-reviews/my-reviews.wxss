@import "../../styles/common.wxss";

.my-review {
  min-height: 100vh;
  background: var(--color-bg-subtle);
}

.my-review__list {
  padding: 8rpx var(--space-page-x) calc(32rpx + env(safe-area-inset-bottom));
}

.my-review__item {
  margin-top: 16rpx;
  padding: 24rpx;
  background: var(--color-bg-page);
  border-radius: var(--radius-md);
  box-shadow: 0 4rpx 16rpx rgba(27, 87, 156, 0.05);
}

.my-review__head {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.my-review__avatar {
  flex-shrink: 0;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  overflow: hidden;
}

.my-review__avatar--placeholder {
  background: var(--color-bg-gray);
}

.my-review__info {
  flex: 1;
  min-width: 0;
}

.my-review__name {
  display: block;
  font-size: var(--text-card-title);
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 1.4;
}

.my-review__rating {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 6rpx;
}

.my-review__stars {
  display: flex;
  gap: 2rpx;
}

.my-review__star {
  font-size: 24rpx;
  color: #e0e0e0;
  line-height: 1;
}

.my-review__star--filled {
  color: var(--color-accent);
}

.my-review__star--half {
  color: var(--color-accent);
  opacity: 0.55;
}

.my-review__score {
  font-size: var(--text-caption);
  font-weight: 600;
  color: var(--color-activity);
  line-height: 1;
}

.my-review__content {
  display: block;
  margin-top: 16rpx;
  font-size: var(--text-body);
  color: var(--color-text-body);
  line-height: 1.5;
}

.my-review__time {
  display: block;
  margin-top: 12rpx;
  font-size: var(--text-caption);
  color: var(--color-text-secondary);
}

.my-review__empty {
  padding: 120rpx 0;
  text-align: center;
  color: var(--color-text-secondary);
  font-size: var(--text-body);
}

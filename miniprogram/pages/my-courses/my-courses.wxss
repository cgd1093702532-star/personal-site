@import "../../styles/common.wxss";

.my-courses {
  min-height: 100vh;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  background: var(--color-bg-subtle);
}

.my-courses__tabs {
  display: flex;
  gap: 0;
  margin: 24rpx var(--space-page-x) 0;
  padding: 6rpx;
  background: #f0f0f0;
  border-radius: 20rpx;
  border-bottom: none;
}

.my-courses__tab {
  flex: 1;
  padding: 16rpx 8rpx;
  text-align: center;
  font-size: 28rpx;
  line-height: 1.2;
  color: #666666;
  white-space: nowrap;
  border-radius: 16rpx;
  background: transparent;
}

.my-courses__tab--active {
  color: #333333;
  font-weight: 600;
  background: #ffffff;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.08);
  border-bottom: none;
}

.my-courses__toolbar {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  padding: 0 var(--space-page-x) 0;
  margin-top: 16rpx;
}

.my-courses__filter {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
}

.my-courses__filter-box {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 32rpx;
  height: 32rpx;
  border: 2rpx solid #cccccc;
  border-radius: 6rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.my-courses__filter--on .my-courses__filter-box {
  border-color: #1b579c;
}

.my-courses__filter-check {
  width: 24rpx;
  height: 24rpx;
}

.my-courses__filter-label {
  font-size: 26rpx;
  line-height: 1.2;
  color: #666666;
}

.my-courses__filter--on .my-courses__filter-label {
  color: #1b579c;
}

.my-courses__list {
  padding: 8rpx var(--space-page-x) 32rpx;
}

.my-courses__relation {
  display: block;
  margin: 0 0 16rpx;
  font-size: 24rpx;
  line-height: 1.2;
  color: #999999;
  text-align: left;
}

.my-courses__card {
  margin-bottom: 24rpx;
  padding: 28rpx;
  background: #ffffff;
  border-radius: 24rpx;
  border: 1rpx solid #eeeeee;
  box-shadow: none;
}

.my-courses__card--ended {
  background: #f5f6f8;
  border-color: #e5e7eb;
}

.my-courses__card--ended .my-courses__cover-img {
  filter: grayscale(0.45);
  opacity: 0.78;
}

.my-courses__card--ended .my-courses__title {
  color: #64748b;
  font-weight: 700;
}

.my-courses__card--ended .my-courses__time,
.my-courses__card--ended .my-courses__place,
.my-courses__card--ended .my-courses__quota {
  color: #94a3b8;
}

.my-courses__card--ended .my-courses__fee,
.my-courses__card--ended .my-courses__fee--muted {
  color: #94a3b8;
  font-weight: 700;
}

.my-courses__card--ended .my-courses__type-tag,
.my-courses__card--ended .my-courses__type-tag--course {
  color: #64748b;
  background: #e2e8f0;
}

.my-courses__card--ended .my-courses__btn--primary {
  background: #e8eaed;
  color: #1f2937;
}

.my-courses__main {
  display: flex;
  gap: 24rpx;
  align-items: flex-start;
}

.my-courses__cover {
  flex-shrink: 0;
  width: 176rpx;
  height: 176rpx;
  border-radius: 20rpx;
  overflow: hidden;
  background: #f5f5f5;
}

.my-courses__cover-img {
  width: 100%;
  height: 100%;
  display: block;
}

.my-courses__info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.my-courses__info-top {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.my-courses__title {
  flex: 1;
  min-width: 0;
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
  line-height: 1.35;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.my-courses__type-tag {
  flex-shrink: 0;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.2;
}

.my-courses__type-tag--course {
  color: #1d4ed8;
  background: #dbeafe;
}

.my-courses__time,
.my-courses__place {
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.4;
}

.my-courses__fee {
  margin-top: 4rpx;
  font-size: 32rpx;
  font-weight: 800;
  color: #ea580c;
  line-height: 1.3;
}

.my-courses__fee--muted {
  color: #94a3b8;
  font-weight: 700;
}

.my-courses__bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 28rpx;
}

.my-courses__quota {
  flex: 1;
  min-width: 0;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.3;
}

.my-courses__actions {
  display: flex;
  justify-content: flex-end;
  flex-shrink: 0;
  gap: 16rpx;
  margin-top: 0;
  padding-top: 0;
  border-top: none;
}

.my-courses__btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 64rpx;
  padding: 0 24rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.my-courses__btn--primary {
  background: var(--color-primary);
  color: #ffffff;
}

.my-courses__empty {
  padding: 120rpx 32rpx;
  text-align: center;
}

.my-courses__empty-icon {
  display: block;
  width: 72rpx;
  height: 72rpx;
  margin: 0 auto;
}

.my-courses__empty-title {
  display: block;
  margin-top: 24rpx;
  font-size: var(--text-card-title);
  font-weight: 600;
  color: var(--color-text-primary);
}

.my-courses__empty-hint {
  display: block;
  margin-top: 12rpx;
  font-size: var(--text-caption);
  color: var(--color-text-secondary);
  line-height: 36rpx;
}

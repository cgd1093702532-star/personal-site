.share-sheet__mask,
.poster-modal__mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 1100;
}

.share-sheet__panel {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(env(safe-area-inset-bottom) + 24rpx);
  z-index: 1101;
  padding: 0;
  background: transparent;
}

.share-sheet__options {
  display: flex;
  flex-direction: column;
  overflow: hidden;
  margin-bottom: 16rpx;
  border-radius: 28rpx;
  background: #fff;
}

.share-sheet__option {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 128rpx;
  border-bottom: 1rpx solid var(--color-divider);
}

.share-sheet__option:last-child {
  border-bottom: none;
}

.share-sheet__option--btn {
  margin: 0;
  padding: 0;
  background: transparent;
  border: none;
  border-bottom: 1rpx solid var(--color-divider);
  border-radius: 0;
  line-height: normal;
}

.share-sheet__option--btn::after {
  border: none;
}

.share-sheet__label {
  font-size: 40rpx;
  font-weight: 500;
  color: var(--color-text-primary);
}

.share-sheet__cancel {
  height: 128rpx;
  line-height: 128rpx;
  text-align: center;
  border-radius: 28rpx;
  background: #fff;
  font-size: 40rpx;
  font-weight: 500;
  color: var(--color-text-primary);
}

.poster-modal__body {
  position: fixed;
  inset: 0;
  z-index: 1101;
}

.poster-modal__img {
  position: absolute;
  left: 90rpx;
  right: 90rpx;
  top: 120rpx;
  width: calc(100% - 180rpx);
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.2);
}

.poster-modal__actions {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  justify-content: center;
  gap: 152rpx;
  min-height: 328rpx;
  padding: 56rpx 48rpx calc(env(safe-area-inset-bottom) + 36rpx);
  border-radius: 56rpx 56rpx 0 0;
  background: #fff;
}

.poster-modal__btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  width: 144rpx;
  color: var(--color-text-secondary);
  font-size: 24rpx;
}

.poster-modal__action-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
}

.poster-modal__action-icon--share {
  background: #e2fae8;
}

.poster-modal__action-icon--save {
  background: #e6f7fd;
}

.poster-modal__action-icon image {
  width: 56rpx;
  height: 56rpx;
}

.poster-canvas {
  position: fixed;
  left: -9999px;
  top: 0;
  width: 300px;
  height: 480px;
}

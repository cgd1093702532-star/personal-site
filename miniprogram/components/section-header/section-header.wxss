.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 52rpx;
  margin-bottom: 24rpx;
}

.section-header__title {
  font-size: var(--text-section-title);
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 52rpx;
}

.section-header__more {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.section-header__more-text {
  font-size: var(--text-body);
  color: var(--color-text-secondary);
  line-height: 36rpx;
}

.section-header__arrow {
  font-size: 32rpx;
  color: var(--color-text-secondary);
  line-height: 1;
}

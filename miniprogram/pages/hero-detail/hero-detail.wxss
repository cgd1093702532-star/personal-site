@import "../../styles/common.wxss";

.hero-detail {
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

/* UGC 个人主页头部 */
.hero-profile {
  position: relative;
  padding-top: 200rpx;
  margin-bottom: 8rpx;
}

.hero-profile__cover {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  z-index: 0;
  height: 200rpx;
  background: linear-gradient(135deg, #dbe6ff 0%, #a8c4f5 55%, #7ba3e8 100%);
}

.hero-detail__share {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  margin-top: 16rpx;
  padding: 10rpx 28rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 4rpx 16rpx rgba(27, 87, 156, 0.12);
}

.hero-detail__share-icon {
  font-size: 24rpx;
  color: var(--color-primary);
}

.hero-detail__share-text {
  font-size: 24rpx;
  color: var(--color-primary);
  font-weight: 500;
}

.hero-profile__main {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: -72rpx;
  padding: 0 var(--space-page-x) 32rpx;
}

.hero-profile__avatar {
  position: relative;
  z-index: 3;
  width: 144rpx;
  height: 144rpx;
  border-radius: 50%;
  border: 6rpx solid var(--color-bg-page);
  box-shadow: 0 8rpx 24rpx rgba(27, 87, 156, 0.15);
}

.hero-profile__name {
  margin-top: 20rpx;
  font-size: 40rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.hero-profile__subtitle {
  margin-top: 8rpx;
  font-size: var(--text-caption);
  color: var(--color-text-secondary);
}

.hero-profile__rating {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 16rpx;
}

.hero-profile__stars {
  display: flex;
  gap: 4rpx;
}

.hero-profile__star {
  font-size: 28rpx;
  color: #e0e0e0;
  line-height: 1;
}

.hero-profile__star--filled {
  color: var(--color-accent);
}

.hero-profile__star--half {
  color: var(--color-accent);
  opacity: 0.55;
}

.hero-profile__score {
  font-size: var(--text-body);
  font-weight: 600;
  color: var(--color-activity);
}

.hero-profile__tags {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 10rpx;
  margin-top: 20rpx;
  max-width: 100%;
}

.hero-profile__tag {
  padding: 6rpx 16rpx;
  border-radius: var(--radius-pill);
  background: var(--color-activity-bg);
  font-size: var(--text-micro);
  color: var(--color-text-body);
}

.hero-profile__stats {
  display: flex;
  width: 100%;
  margin-top: 32rpx;
  padding: 24rpx 0;
  background: var(--color-bg-subtle);
  border-radius: var(--radius-md);
}

.hero-profile__stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.hero-profile__stat-num {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.hero-profile__stat-num--text {
  font-size: 24rpx;
  line-height: 1.25;
  font-weight: 600;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  word-break: break-all;
}

.hero-profile__stat-label {
  font-size: var(--text-micro);
  color: var(--color-text-secondary);
}

.hero-detail__block {
  margin-top: 32rpx;
  padding: 0 var(--space-page-x);
}

.hero-detail__label {
  display: block;
  margin-bottom: 16rpx;
  font-size: var(--text-section-title);
  font-weight: 600;
  color: var(--color-text-primary);
}

.hero-detail__bio {
  font-size: var(--text-body);
  color: var(--color-text-body);
  line-height: 44rpx;
  white-space: pre-wrap;
}

.hero-detail__honor {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--color-divider);
}

.hero-detail__honor:last-child {
  border-bottom: none;
}

.hero-detail__honor-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: var(--radius-md);
  background: var(--color-bg-subtle);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.hero-detail__honor-icon-img {
  width: 36rpx;
  height: 36rpx;
}

.hero-detail__honor-body {
  flex: 1;
  min-width: 0;
}

.hero-detail__honor-name {
  display: block;
  font-size: var(--text-card-title);
  font-weight: 500;
  color: var(--color-text-primary);
}

.hero-detail__honor-summary {
  display: block;
  margin-top: 6rpx;
  font-size: var(--text-caption);
  color: var(--color-text-secondary);
}

.hero-detail__gallery {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.hero-detail__gallery-item {
  width: calc((100% - 24rpx) / 3);
  height: 200rpx;
  border-radius: var(--radius-md);
}

.hero-detail__cert-scroll {
  white-space: nowrap;
  width: 100%;
}

.hero-detail__cert-card {
  display: inline-flex;
  flex-direction: column;
  width: 200rpx;
  margin-right: 16rpx;
  vertical-align: top;
}

.hero-detail__cert-card:last-child {
  margin-right: 0;
}

.hero-detail__cert-img {
  width: 200rpx;
  height: 140rpx;
  border-radius: var(--radius-md);
}

.hero-detail__cert-name {
  display: block;
  margin-top: 10rpx;
  font-size: var(--text-caption);
  color: var(--color-text-body);
  text-align: center;
  white-space: normal;
  line-height: 32rpx;
}

.hero-detail__label-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.hero-detail__label-extra {
  font-size: var(--text-caption);
  color: var(--color-text-secondary);
}

.hero-detail__recruit-card {
  display: flex;
  gap: 24rpx;
  align-items: flex-start;
  padding: 24rpx;
  margin-bottom: 16rpx;
  background: var(--color-bg-subtle);
  border-radius: var(--radius-md);
}

.hero-detail__recruit-card:last-child {
  margin-bottom: 0;
}

.hero-detail__recruit-card:active {
  opacity: 0.88;
}

.hero-detail__recruit-thumb {
  width: 144rpx;
  height: 144rpx;
  border-radius: var(--radius-md);
  flex-shrink: 0;
  overflow: hidden;
}

.hero-detail__recruit-thumb--0 {
  background: linear-gradient(135deg, #e8f4fc 0%, #b8dff5 100%);
}

.hero-detail__recruit-thumb--1 {
  background: linear-gradient(135deg, #fef3e2 0%, #f5c98a 100%);
}

.hero-detail__recruit-thumb--2 {
  background: linear-gradient(135deg, #e8fce8 0%, #a8e6a8 100%);
}

.hero-detail__recruit-body {
  flex: 1;
  min-width: 0;
}

.hero-detail__recruit-title {
  display: block;
  font-size: var(--text-card-title);
  font-weight: 600;
  color: var(--color-text-primary);
}

.hero-detail__recruit-meta {
  display: block;
  margin-top: 8rpx;
  font-size: var(--text-caption);
  color: var(--color-text-secondary);
  line-height: 36rpx;
}

.hero-detail__recruit-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
}

.hero-detail__recruit-fee {
  font-size: var(--text-body);
  font-weight: 600;
  color: var(--color-price);
}

.hero-detail__recruit-signup {
  font-size: var(--text-caption);
  color: var(--color-text-secondary);
}

.hero-detail__course-card {
  display: flex;
  gap: 24rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  background: var(--color-bg-subtle);
  border-radius: var(--radius-md);
}

.hero-detail__course-card:last-child {
  margin-bottom: 0;
}

.hero-detail__course-card:active {
  opacity: 0.88;
}

.hero-detail__course-thumb {
  width: 144rpx;
  height: 144rpx;
  border-radius: var(--radius-md);
  flex-shrink: 0;
  overflow: hidden;
}

.hero-detail__course-thumb--0 {
  background: linear-gradient(135deg, #dbe6ff 0%, #7ba3e8 100%);
}

.hero-detail__course-thumb--1 {
  background: linear-gradient(135deg, #ffe8c8 0%, #f5a623 100%);
}

.hero-detail__course-thumb--2 {
  background: linear-gradient(135deg, #d4f5e9 0%, #27ae60 100%);
}

.hero-detail__course-body {
  flex: 1;
  min-width: 0;
}

.hero-detail__course-body .hero-detail__recruit-bottom {
  margin-top: 8rpx;
}

.hero-detail__bottom-spacer {
  height: 48rpx;
}

@import "../../styles/common.wxss";

.my-orders {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.my-orders__tabs {
  display: flex;
  padding: 0 16rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
  overflow-x: auto;
  white-space: nowrap;
}

.my-orders__tab {
  flex-shrink: 0;
  padding: 24rpx 20rpx;
  font-size: 26rpx;
  color: #333333;
  position: relative;
}

.my-orders__tab--active {
  color: #1b579c;
  font-weight: 600;
}

.my-orders__tab--active::after {
  content: '';
  position: absolute;
  left: 50%;
  bottom: 0;
  width: 48rpx;
  height: 4rpx;
  margin-left: -24rpx;
  background: #1b579c;
  border-radius: 2rpx;
}

.my-orders__list {
  padding: 24rpx 24rpx 0;
}

.my-orders__card {
  margin-bottom: 24rpx;
  padding: 28rpx;
  background: #ffffff;
  border-radius: 20rpx;
}

.my-orders__card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.my-orders__shop {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}

.my-orders__shop-icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.my-orders__shop-name {
  font-size: 26rpx;
  color: #333333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.my-orders__status {
  flex-shrink: 0;
  margin-left: 16rpx;
  font-size: 26rpx;
  color: #e8772e;
}

.my-orders__body {
  display: flex;
  gap: 20rpx;
}

.my-orders__cover {
  width: 144rpx;
  height: 144rpx;
  border-radius: 12rpx;
  overflow: hidden;
  flex-shrink: 0;
  background: #eeeeee;
}

.my-orders__cover-img {
  width: 100%;
  height: 100%;
}

.my-orders__info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.my-orders__title {
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.35;
  color: #222222;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.my-orders__price-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-top: 16rpx;
}

.my-orders__price {
  font-size: 26rpx;
  color: #333333;
}

.my-orders__qty {
  font-size: 24rpx;
  color: #999999;
}

.my-orders__paid {
  margin-top: 24rpx;
  text-align: right;
  font-size: 26rpx;
  color: #333333;
}

.my-orders__actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 24rpx;
}

.my-orders__btn {
  min-width: 176rpx;
  height: 60rpx;
  line-height: 60rpx;
  padding: 0 24rpx;
  text-align: center;
  border: 1rpx solid #dddddd;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #333333;
  background: #ffffff;
}

.my-orders__empty {
  padding: 160rpx 48rpx 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.my-orders__empty-icon {
  width: 96rpx;
  height: 96rpx;
  opacity: 0.45;
}

.my-orders__empty-title {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #999999;
}

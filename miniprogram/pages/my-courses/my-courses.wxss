@import "../../styles/common.wxss";

.my-courses {
  min-height: 100vh;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  background: var(--color-bg-subtle);
}

.my-courses__tabs {
  display: flex;
  gap: 0;
  margin: 24rpx var(--space-page-x) 0;
  padding: 6rpx;
  background: #f0f0f0;
  border-radius: 20rpx;
  border-bottom: none;
}

.my-courses__tab {
  flex: 1;
  padding: 16rpx 8rpx;
  text-align: center;
  font-size: 28rpx;
  line-height: 1.2;
  color: #666666;
  white-space: nowrap;
  border-radius: 16rpx;
  background: transparent;
}

.my-courses__tab--active {
  color: #333333;
  font-weight: 600;
  background: #ffffff;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.08);
  border-bottom: none;
}

.my-courses__list {
  padding: 32rpx var(--space-page-x);
}

.my-courses__card {
  margin-bottom: 20rpx;
  padding: 24rpx;
  background: var(--color-bg-page);
  border-radius: var(--radius-md);
  border-left: 6rpx solid var(--color-primary);
  box-shadow: 0 4rpx 16rpx rgba(27, 87, 156, 0.06);
}

.my-courses__card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.my-courses__title {
  flex: 1;
  font-size: var(--text-card-title);
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 1.4;
}

.my-courses__badge {
  flex-shrink: 0;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: var(--color-text-secondary);
  background: var(--color-bg-gray);
}

.my-courses__meta {
  display: block;
  margin-top: 12rpx;
  font-size: var(--text-caption);
  color: var(--color-text-secondary);
}

.my-courses__price {
  display: block;
  margin-top: 8rpx;
  font-size: var(--text-body);
  color: var(--color-price);
  font-weight: 600;
}

.my-courses__progress {
  margin-top: 16rpx;
  font-size: var(--text-caption);
  color: var(--color-text-secondary);
}

.my-courses__bar {
  height: 12rpx;
  margin-top: 8rpx;
  background: var(--color-divider);
  border-radius: 6rpx;
  overflow: hidden;
}

.my-courses__bar-inner {
  height: 100%;
  background: var(--color-primary);
  border-radius: 6rpx;
}

.my-courses__actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--color-divider);
}

.my-courses__btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 64rpx;
  padding: 0 24rpx;
  border-radius: 16rpx;
  background: var(--color-primary);
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 500;
}

.my-courses__empty {
  padding: 120rpx 32rpx;
  text-align: center;
}

.my-courses__empty-icon {
  display: block;
  width: 72rpx;
  height: 72rpx;
  margin: 0 auto;
}

.my-courses__empty-title {
  display: block;
  margin-top: 24rpx;
  font-size: var(--text-card-title);
  font-weight: 600;
  color: var(--color-text-primary);
}

.my-courses__empty-hint {
  display: block;
  margin-top: 12rpx;
  font-size: var(--text-caption);
  color: var(--color-text-secondary);
  line-height: 36rpx;
}

<view class="home">
  <!-- Banner -->
  <view class="home-banner">
    <view class="home-banner__bg cover-placeholder"></view>
    <view class="home-banner__fade"></view>
    <view class="home-banner__safe" style="height: {{statusBarHeight}}px;"></view>
    <view class="home-banner__season">
      <text class="home-banner__pin">📍</text>
      <text>{{banner.season}}</text>
    </view>
    <view class="home-banner__content">
      <text class="home-banner__title">{{banner.title}}</text>
      <text class="home-banner__date">{{banner.subtitle}}</text>
      <text class="home-banner__desc">{{banner.desc}}</text>
      <view class="home-banner__cta" bindtap="onBannerCta">{{banner.cta}}</view>
    </view>
  </view>

  <!-- 金刚区 -->
  <view class="home-nav section">
    <view class="home-nav__item" wx:for="{{shortNav}}" wx:key="id">
      <view class="home-nav__icon">
        <image class="home-nav__icon-img" src="{{item.icon}}" mode="aspectFit" />
      </view>
      <text class="home-nav__label">{{item.label}}</text>
    </view>
  </view>

  <!-- 权益卡 -->
  <view class="membership section">
    <view class="membership__card">
      <view class="membership__main">
        <view class="membership__info">
          <text class="membership__title"><text class="membership__title-white">航海家</text><text class="membership__title-gold">权益卡</text></text>
          <view class="membership__price">
            <text class="membership__price-symbol">¥ </text>
            <text class="membership__price-num">{{membership.price}}</text>
          </view>
        </view>
        <view class="membership__btn">立即开通 →</view>
      </view>
      <view class="membership__footer">
        <view class="membership__benefit" wx:for="{{membership.benefits}}" wx:key="*this">
          <text class="membership__check">✓</text>
          <text>{{item}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 英雄广场：至少 1 个推荐教练才展示整块 -->
  <view class="section" wx:if="{{heroes.length}}">
    <section-header title="英雄广场" bind:more="onHeroMore" />
    <scroll-view class="home-scroll-x" scroll-x enable-flex show-scrollbar="{{false}}" enhanced>
      <view class="home-scroll-x__track">
        <hero-card wx:for="{{heroes}}" wx:key="hero_id" hero="{{item}}" layout="home" bind:tap="onHeroTap" />
      </view>
    </scroll-view>
  </view>

  <!-- 精选活动与赛事 -->
  <view class="section">
    <section-header title="精选活动与赛事" bind:more="onHeroMore" />
    <event-card wx:for="{{events}}" wx:key="recruit_id" item="{{item}}" bind:tap="onEventTap" />
  </view>

  <!-- 精选课程 -->
  <view class="section">
    <section-header title="精选课程" bind:more="onHeroMore" />
    <scroll-view class="home-scroll-x" scroll-x enable-flex show-scrollbar="{{false}}" enhanced>
      <view class="home-scroll-x__track">
        <view class="course-card" wx:for="{{courses}}" wx:key="id">
          <view class="course-card__cover cover-placeholder cover-placeholder--green"></view>
          <text class="course-card__title text-ellipsis-2">{{item.title}}</text>
          <text class="course-card__price">{{item.price === '待定中' ? item.price : '¥' + item.price}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 精选好物 -->
  <view class="section">
    <section-header title="精选好物" bind:more="onHeroMore" />
    <view class="product-grid">
      <view class="product-card" wx:for="{{products}}" wx:key="id">
        <view class="product-card__cover cover-placeholder {{index === 0 ? 'cover-placeholder--warm' : 'cover-placeholder--gray'}}">
          <text wx:if="{{item.tag}}" class="product-card__tag">{{item.tag}}</text>
        </view>
        <text class="product-card__title text-ellipsis">{{item.title}}</text>
        <text class="product-card__price">¥{{item.price}}</text>
      </view>
    </view>
  </view>

  <!-- 新闻动态 -->
  <view class="section section--last">
    <section-header title="新闻动态" bind:more="onHeroMore" />
    <view class="news-item" wx:for="{{news}}" wx:key="id">
      <view class="news-item__cover cover-placeholder cover-placeholder--gray"></view>
      <view class="news-item__body">
        <text class="news-item__title text-ellipsis-2">{{item.title}}</text>
        <text class="news-item__cat">{{item.category}}</text>
      </view>
    </view>
  </view>
</view>

.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
  height: 28rpx;
  border-radius: var(--radius-sm);
  font-size: var(--text-micro);
  line-height: 28rpx;
}

.tag--event {
  background: #fff3b8;
  color: #9a7b00;
}

.tag--activity {
  background: #fde3d4;
  color: #c45a18;
}

.tag--course {
  background: #d8f5e8;
  color: #1f8a5a;
}

.tag--skill {
  background: #fff;
  color: #222;
  border: 1rpx solid #e5e8eb;
}

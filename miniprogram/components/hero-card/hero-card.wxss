.hero-card {
  display: block;
  flex-shrink: 0;
  width: 528rpx;
  padding: 24rpx;
  margin-right: 16rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #e8efff 0%, #f5f8ff 100%);
  box-sizing: border-box;
}

.hero-card--list {
  display: block;
  width: 100%;
  margin-right: 0;
  margin-bottom: 24rpx;
  padding: 24rpx;
}

.hero-card--list:last-child {
  margin-bottom: 0;
}

.hero-card--list .hero-card__avatar {
  width: 112rpx;
  height: 112rpx;
}

.hero-card--list .hero-card__name {
  font-size: 32rpx;
  font-weight: 700;
}

.hero-card--list .hero-card__row {
  height: 68rpx;
  margin-bottom: 16rpx;
  background: #fff;
}

.hero-card--list .hero-card__row:last-child {
  margin-bottom: 0;
}

.hero-card__head {
  display: flex;
  gap: 16rpx;
}

.hero-card__avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--radius-md);
  flex-shrink: 0;
}

.hero-card__meta {
  flex: 1;
  min-width: 0;
}

.hero-card__name-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
}

.hero-card__name {
  font-size: var(--text-card-title);
  font-weight: 600;
  color: var(--color-text-primary);
}

.hero-card__tags {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.hero-card__badge {
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: 500;
  color: #fff;
  background: #b0b8c2;
}

.hero-card__tags .tag--skill {
  background: #fff;
  color: #222;
  border: 1rpx solid #e5e8eb;
}

.hero-card__honors {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}

.hero-card__honor {
  display: inline-flex;
  align-items: center;
  max-width: 100%;
  min-height: 32rpx;
  height: auto;
  border-radius: var(--radius-sm);
  overflow: hidden;
}

.hero-card__honor--primary {
  background: #fde3d4;
}

.hero-card__honor-icon {
  width: 32rpx;
  height: 32rpx;
  background: #f47528;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.hero-card__honor-icon-img {
  width: 20rpx;
  height: 20rpx;
}

.hero-card__honor-text {
  padding: 0 10rpx;
  font-size: var(--text-micro);
  color: #5c4a3a;
  white-space: normal;
  word-break: break-all;
}

.hero-card__honor--secondary {
  background: #fff0e6;
}

.hero-card__honor--secondary .hero-card__honor-icon {
  display: none;
}

.hero-card__honor--secondary .hero-card__honor-text {
  color: #5c4a3a;
  padding: 4rpx 12rpx;
}

.hero-card__rows {
  margin-top: 16rpx;
}

.hero-card__row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  height: 64rpx;
  padding: 0 16rpx;
  margin-bottom: 8rpx;
  background: var(--color-overlay-card);
  border-radius: var(--radius-md);
}

.hero-card__row:active {
  opacity: 0.85;
}

.hero-card__row:last-child {
  margin-bottom: 0;
}

.hero-card__row-text {
  flex: 1;
  font-size: var(--text-body);
  font-weight: 500;
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hero-card__row-arrow {
  color: var(--color-text-secondary);
  font-size: 28rpx;
  flex-shrink: 0;
  width: 36rpx;
  height: 36rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border: 1rpx dashed #d0d5dd;
  border-radius: 8rpx;
  line-height: 1;
}

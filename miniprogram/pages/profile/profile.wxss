@import "../../styles/common.wxss";

.profile {
  padding: 0;
  background: transparent;
}

.profile-page {
  min-height: 100%;
  padding-bottom: 48rpx;
  background: linear-gradient(180deg, #dce9f8 0%, #eef3f8 240rpx, #f2f4f7 440rpx, #f2f4f7 100%);
}

.profile-user {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 32rpx 32rpx 16rpx;
}

.profile-user__head {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.profile-user__info {
  flex: 1;
  min-width: 0;
}

.profile-user__msg {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  margin-left: auto;
}

.profile-user__msg--active {
  opacity: 0.72;
}

.profile-user__msg-icon {
  width: 44rpx;
  height: 44rpx;
}

.profile-user__avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.profile-user__name {
  display: block;
  font-size: var(--text-section-title);
  font-weight: 600;
  color: var(--color-text-primary);
}

.profile-user__member {
  font-size: var(--text-body);
  color: var(--color-text-secondary);
}

.profile-user__meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 8rpx;
}

.profile-user__cert {
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  font-size: var(--text-caption);
  font-weight: 500;
}

.profile-user__cert--none {
  background: #f0f2f5;
  color: var(--color-text-secondary);
}

.profile-user__cert--hero {
  background: #e8f5e9;
  color: #09633f;
}

.profile-vip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 8rpx 32rpx 0;
  padding: 32rpx 36rpx;
  border-radius: 24rpx;
  background: linear-gradient(120deg, #0a2f6b 0%, #163f86 45%, #1b579c 100%);
  box-shadow: 0 16rpx 40rpx rgba(12, 60, 134, 0.28);
}

.profile-vip:active {
  opacity: 0.92;
}

.profile-vip__title {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
}

.profile-vip__title-gold {
  color: #e3c086;
  margin-left: 4rpx;
}

.profile-vip__cta {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.92);
}

.profile-assets {
  display: flex;
  justify-content: space-around;
  margin: 24rpx 32rpx 0;
  padding: 32rpx 16rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(27, 87, 156, 0.06);
}

.profile-assets__item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.profile-assets__item:active {
  opacity: 0.7;
}

.profile-assets__num {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1.2;
}

.profile-assets__label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.profile-hero-center {
  margin: 32rpx 32rpx 0;
  padding: 28rpx 24rpx 24rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(27, 87, 156, 0.06);
}

.profile-hero-center .profile-section__title {
  margin: 0 8rpx 24rpx;
}

.profile-orders {
  margin: 24rpx 32rpx 0;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(27, 87, 156, 0.06);
  overflow: hidden;
}

.profile-orders__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
}

.profile-orders__title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.profile-orders__more {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.profile-orders__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  padding: 8rpx 16rpx 36rpx;
  gap: 8rpx;
}

.profile-orders__item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
}

.profile-orders__icon-wrap {
  position: relative;
  width: 56rpx;
  height: 56rpx;
}

.profile-orders__icon {
  width: 56rpx;
  height: 56rpx;
  display: block;
}

.profile-orders__badge {
  position: absolute;
  top: -12rpx;
  right: -20rpx;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  border-radius: 16rpx;
  background: #ff4d4f;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 600;
  line-height: 32rpx;
  text-align: center;
  box-sizing: border-box;
}

.profile-orders__label {
  font-size: 22rpx;
  color: var(--color-text-primary);
  text-align: center;
  line-height: 1.3;
  white-space: nowrap;
}

.profile-hero-shortcuts {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.profile-hero-shortcuts__row {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 16rpx;
}

.profile-hero-shortcuts__item {
  min-width: 0;
  width: 100%;
  box-sizing: border-box;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx 8rpx;
  background: linear-gradient(180deg, #eef4ff 0%, #f6f9ff 100%);
  border: 1rpx solid rgba(27, 87, 156, 0.12);
  border-radius: var(--radius-md);
  box-shadow: 0 4rpx 16rpx rgba(27, 87, 156, 0.08);
}

.profile-hero-shortcuts__badge {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  z-index: 1;
  padding: 2rpx 10rpx;
  border-radius: 16rpx;
  font-size: 20rpx;
  line-height: 1.4;
  font-weight: 500;
  color: #fff;
  background: #e6a23c;
  white-space: nowrap;
}

.profile-hero-shortcuts__item:active {
  opacity: 0.85;
}

.profile-hero-shortcuts__icon {
  width: 40rpx;
  height: 40rpx;
  display: block;
}

.profile-hero-shortcuts__label {
  font-size: var(--text-micro);
  font-weight: 500;
  color: var(--color-text-primary);
  text-align: center;
  line-height: 28rpx;
}

.profile-hero-cta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin: 24rpx 32rpx 0;
  padding: 24rpx;
  background: linear-gradient(135deg, #fff9e6 0%, #fff3cc 100%);
  border: 2rpx solid var(--color-accent);
  border-radius: var(--radius-md);
  box-shadow: 0 8rpx 24rpx rgba(254, 207, 19, 0.2);
}

.profile-hero-cta--pending {
  background: var(--color-bg-subtle);
  border-color: var(--color-divider);
  box-shadow: none;
}

.profile-hero-cta--rejected {
  background: #fff7f7;
  border-color: #ffccc7;
  box-shadow: none;
}

.profile-hero-cta__hint {
  flex: 1;
  min-width: 0;
  font-size: var(--text-caption);
  line-height: 36rpx;
  color: var(--color-text-body);
}

.profile-hero-cta__btn {
  flex-shrink: 0;
  padding: 20rpx 28rpx;
  background: var(--color-accent);
  border-radius: var(--radius-md);
  font-size: var(--text-body);
  font-weight: 600;
  color: var(--color-text-primary);
  box-shadow: 0 4rpx 12rpx rgba(254, 207, 19, 0.35);
}

.profile-hero-cta__btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.profile-section {
  margin: 32rpx 32rpx 0;
}

.profile-section__title {
  display: block;
  margin-bottom: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: left;
  color: var(--color-text-primary);
}

.profile-section__title--in-card {
  margin: 16rpx 0 8rpx;
  padding: 8rpx 0 16rpx;
}

.profile-section__card {
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(27, 87, 156, 0.06);
  overflow: hidden;
  padding: 8rpx 32rpx;
}

.profile-section__card .profile-menu__item:last-child {
  border-bottom: 0;
}

.profile-menu__item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx 0;
  border-bottom: 1rpx solid var(--color-divider);
}

.profile-menu__icon {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-md);
  background: var(--color-bg-subtle);
  flex-shrink: 0;
}

.profile-menu__body {
  flex: 1;
  min-width: 0;
}

.profile-menu__title {
  display: block;
  font-size: var(--text-card-title);
  color: var(--color-text-primary);
}

.profile-menu__arrow {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  flex-shrink: 0;
}

.profile-action-sheet {
  position: fixed;
  inset: 0;
  z-index: 2000;
}

.profile-action-sheet__mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
}

.profile-action-sheet__panel {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx var(--space-page-x) calc(16rpx + env(safe-area-inset-bottom));
  background: var(--color-bg-page);
  border-radius: 24rpx 24rpx 0 0;
}

.profile-action-sheet__item {
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  font-size: var(--text-body);
  color: var(--color-text-primary);
  border-bottom: 1rpx solid var(--color-divider);
}

.profile-action-sheet__item:last-child {
  border-bottom: none;
}

.profile-action-sheet__item:active {
  background: var(--color-bg-subtle);
}

.profile-action-sheet__item--cancel {
  margin-top: 8rpx;
  border-radius: var(--radius-md);
  border-bottom: none;
  color: var(--color-text-secondary);
}

.profile-dialog {
  position: fixed;
  inset: 0;
  z-index: 2000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}

.profile-dialog__mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
}

.profile-dialog__panel {
  position: relative;
  z-index: 1;
  width: 560rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.18);
}

.profile-dialog__title {
  display: block;
  padding: 40rpx 40rpx 16rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  text-align: center;
}

.profile-dialog__body {
  display: block;
  padding: 0 40rpx 32rpx;
  font-size: 28rpx;
  line-height: 1.5;
  color: var(--color-text-body);
  text-align: center;
  word-break: break-word;
}

.profile-dialog__actions {
  display: flex;
  border-top: 1rpx solid var(--color-divider);
}

.profile-dialog__btn {
  flex: 1;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  font-size: 30rpx;
  color: var(--color-text-secondary);
}

.profile-dialog__btn + .profile-dialog__btn {
  border-left: 1rpx solid var(--color-divider);
}

.profile-dialog__btn--primary {
  color: var(--color-primary);
  font-weight: 600;
}

.profile-dialog__btn:active {
  background: var(--color-bg-subtle);
}

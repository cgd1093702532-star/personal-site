@import "../../styles/common.wxss";

.my-recruit {
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  background: var(--color-bg-subtle);
}

.my-recruit__tabs {
  position: sticky;
  top: 0;
  z-index: 12;
  margin: 0;
  padding: 24rpx var(--space-page-x) 16rpx;
  background: var(--color-bg-subtle);
  box-sizing: border-box;
}

.my-recruit__tabs-track {
  display: flex;
  gap: 0;
  padding: 6rpx;
  background: #f0f0f0;
  border-radius: 20rpx;
}

.my-recruit__tab {
  flex: 1;
  padding: 16rpx 8rpx;
  text-align: center;
  font-size: 28rpx;
  line-height: 1.2;
  color: #666666;
  white-space: nowrap;
  border-radius: 16rpx;
  background: transparent;
}

.my-recruit__tab--active {
  color: #333333;
  font-weight: 600;
  background: #ffffff;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.08);
  border-bottom: none;
}

.my-recruit__toolbar {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  padding: 0 var(--space-page-x) 0;
}

.my-recruit__filter {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
}

.my-recruit__filter-box {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 32rpx;
  height: 32rpx;
  border: 2rpx solid #cccccc;
  border-radius: 6rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.my-recruit__filter--on .my-recruit__filter-box {
  border-color: #1b579c;
}

.my-recruit__filter-check {
  width: 24rpx;
  height: 24rpx;
}

.my-recruit__filter-label {
  font-size: 26rpx;
  line-height: 1.2;
  color: #666666;
}

.my-recruit__filter--on .my-recruit__filter-label {
  color: #1b579c;
}

.my-recruit__overview {
  display: flex;
  gap: 16rpx;
  padding: 24rpx var(--space-page-x);
}

.my-recruit__stat-card {
  flex: 1;
  padding: 24rpx 20rpx;
  border-radius: var(--radius-md);
  border: 1rpx solid transparent;
}

.my-recruit__stat-card--signup {
  background: linear-gradient(135deg, #eef4ff 0%, #f6f9ff 100%);
  border-color: rgba(27, 87, 156, 0.12);
}

.my-recruit__stat-card--income {
  background: linear-gradient(135deg, #fff8e6 0%, #fffdf5 100%);
  border-color: rgba(254, 207, 19, 0.35);
}

.my-recruit__stat-num {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 1.2;
}

.my-recruit__stat-label {
  display: block;
  margin-top: 8rpx;
  font-size: var(--text-caption);
  color: var(--color-text-secondary);
}

.my-recruit__list {
  padding: 8rpx var(--space-page-x) 0;
}

.my-recruit__relation {
  display: block;
  margin: 0 0 16rpx;
  font-size: 24rpx;
  line-height: 1.2;
  color: #999999;
  text-align: left;
}

.my-recruit__card {
  margin-bottom: 24rpx;
  padding: 28rpx;
  background: #ffffff;
  border-radius: 24rpx;
  border: 1rpx solid #eeeeee;
  box-shadow: none;
}

.my-recruit__card--draft {
  padding: 28rpx;
  border: 1rpx solid rgba(27, 87, 156, 0.12);
  background: linear-gradient(180deg, #eef4ff 0%, #f6f9ff 100%);
  box-shadow: none;
}

.my-recruit__card--ended {
  background: #f5f6f8;
  border-color: #e5e7eb;
}

.my-recruit__card--ended .my-recruit__cover-img {
  filter: grayscale(0.45);
  opacity: 0.78;
}

.my-recruit__card--ended .my-recruit__title {
  color: #64748b;
  font-weight: 700;
}

.my-recruit__card--ended .my-recruit__time,
.my-recruit__card--ended .my-recruit__place,
.my-recruit__card--ended .my-recruit__quota {
  color: #94a3b8;
}

.my-recruit__card--ended .my-recruit__fee,
.my-recruit__card--ended .my-recruit__fee--muted {
  color: #94a3b8;
  font-weight: 700;
}

.my-recruit__card--ended .my-recruit__type-tag,
.my-recruit__card--ended .my-recruit__type-tag--event,
.my-recruit__card--ended .my-recruit__type-tag--activity,
.my-recruit__card--ended .my-recruit__type-tag--course {
  color: #64748b;
  background: #e2e8f0;
}

.my-recruit__main {
  display: flex;
  gap: 24rpx;
  align-items: flex-start;
}

.my-recruit__cover {
  flex-shrink: 0;
  width: 176rpx;
  height: 176rpx;
  border-radius: 20rpx;
  overflow: hidden;
  background: #f5f5f5;
}

.my-recruit__cover-img {
  width: 100%;
  height: 100%;
  display: block;
}

.my-recruit__info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.my-recruit__info-top {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.my-recruit__title {
  flex: 1;
  min-width: 0;
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
  line-height: 1.35;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.my-recruit__type-tag {
  flex-shrink: 0;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.2;
}

.my-recruit__type-tag--event {
  color: #b45309;
  background: #fef3c7;
}

.my-recruit__type-tag--activity {
  color: #c2410c;
  background: #ffedd5;
}

.my-recruit__type-tag--course {
  color: #1d4ed8;
  background: #dbeafe;
}

.my-recruit__time,
.my-recruit__place {
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.4;
}

.my-recruit__fee {
  margin-top: 4rpx;
  font-size: 32rpx;
  font-weight: 800;
  color: #ea580c;
  line-height: 1.3;
}

.my-recruit__fee--muted {
  color: #94a3b8;
  font-weight: 700;
}

.my-recruit__bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 28rpx;
}

.my-recruit__quota {
  flex: 1;
  min-width: 0;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.3;
}

.my-recruit__actions {
  display: flex;
  justify-content: flex-end;
  flex-shrink: 0;
  gap: 16rpx;
  margin-top: 0;
  padding-top: 0;
  border-top: none;
}

.my-recruit__card--draft .my-recruit__actions {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(27, 87, 156, 0.1);
}

.my-recruit__draft-head {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.my-recruit__draft-icon-wrap {
  flex-shrink: 0;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-md);
  background: rgba(255, 255, 255, 0.85);
}

.my-recruit__draft-icon {
  width: 36rpx;
  height: 36rpx;
}

.my-recruit__draft-body {
  flex: 1;
  min-width: 0;
}

.my-recruit__draft-body .my-recruit__title {
  display: block;
}

.my-recruit__draft-hint {
  display: block;
  margin-top: 6rpx;
  font-size: var(--text-caption);
  color: var(--color-text-secondary);
}

.my-recruit__draft-meta {
  padding: 16rpx 20rpx;
  border-radius: var(--radius-md);
  background: rgba(255, 255, 255, 0.72);
}

.my-recruit__draft-meta .my-recruit__row {
  margin-bottom: 6rpx;
}

.my-recruit__draft-meta .my-recruit__row:last-child {
  margin-bottom: 0;
}

.my-recruit__draft-plan {
  display: block;
  font-size: var(--text-caption);
  color: var(--color-text-body);
  line-height: 36rpx;
}

.my-recruit__actions--draft {
  margin-top: 20rpx;
}

.my-recruit__actions--draft .my-recruit__btn--primary {
  flex: 1.6;
}

.my-recruit__btn--ghost {
  background: transparent;
  color: var(--color-text-secondary);
  border: 1rpx solid rgba(27, 87, 156, 0.18);
}

.my-recruit__badge {
  flex-shrink: 0;
  padding: 4rpx 14rpx;
  border-radius: var(--radius-pill);
  font-size: var(--text-micro);
  font-weight: 500;
}

.my-recruit__badge--recruiting {
  background: rgba(254, 207, 19, 0.35);
  color: #8a6d00;
}

.my-recruit__badge--ongoing {
  background: rgba(0, 199, 119, 0.2);
  color: var(--color-course-tag);
}

.my-recruit__badge--closed,
.my-recruit__badge--ended {
  background: var(--color-bg-gray);
  color: var(--color-text-secondary);
}

.my-recruit__badge--draft {
  background: rgba(27, 87, 156, 0.1);
  color: var(--color-primary);
}

.my-recruit__row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 10rpx;
}

.my-recruit__row-icon {
  flex-shrink: 0;
  width: 28rpx;
  height: 28rpx;
  margin-top: 4rpx;
}

.my-recruit__row-text {
  font-size: var(--text-caption);
  color: var(--color-text-secondary);
  line-height: 36rpx;
}

.my-recruit__btn {
  flex: 0 0 auto;
  min-width: 0;
  height: 64rpx;
  padding: 0 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  border-radius: var(--radius-md);
  font-size: var(--text-caption);
  font-weight: 500;
}

.my-recruit__btn-icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
}

.my-recruit__btn--primary {
  flex: 0 0 auto;
  background: var(--color-primary);
  color: var(--color-text-inverse);
}

.my-recruit__btn--outline {
  background: var(--color-bg-page);
  color: var(--color-text-body);
  border: 1rpx solid var(--color-divider);
}

.my-recruit__btn--danger {
  background: rgba(244, 117, 40, 0.12);
  color: var(--color-activity);
}

.my-recruit__btn:active {
  opacity: 0.88;
}

.my-recruit__empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 48rpx 160rpx;
  text-align: center;
}

.my-recruit__empty-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 24rpx;
}

.my-recruit__empty-title {
  font-size: var(--text-section-title);
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 44rpx;
}

.my-recruit__empty-hint {
  margin-top: 12rpx;
  font-size: var(--text-caption);
  color: var(--color-text-secondary);
  line-height: 40rpx;
  max-width: 480rpx;
}

.my-recruit__empty-btn {
  margin-top: 32rpx;
  padding: 0 48rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: var(--radius-md);
  background: var(--color-primary);
  color: var(--color-text-inverse);
  font-size: var(--text-body);
  font-weight: 500;
}

.my-recruit__empty-btn:active {
  opacity: 0.88;
}

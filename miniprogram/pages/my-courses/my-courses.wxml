<view class="page my-courses">
  <view class="my-courses__tabs">
    <view
      wx:for="{{tabs}}"
      wx:key="key"
      class="my-courses__tab {{activeTab === item.key ? 'my-courses__tab--active' : ''}}"
      data-key="{{item.key}}"
      bindtap="onTabChange"
    >{{item.display}}</view>
  </view>

  <view class="my-courses__toolbar" wx:if="{{showOnlyMineFilter}}">
    <view class="my-courses__filter {{onlyMine ? 'my-courses__filter--on' : ''}}" bindtap="onToggleOnlyMine">
      <view class="my-courses__filter-box">
        <image wx:if="{{onlyMine}}" class="my-courses__filter-check" src="/assets/icons/check-primary.png" mode="aspectFit" />
      </view>
      <text class="my-courses__filter-label">仅显示我发起的</text>
    </view>
  </view>

  <view class="my-courses__list">
    <block wx:for="{{currentList}}" wx:key="course_id">
      <view
        class="my-courses__card {{item.listTab === 'ended' ? 'my-courses__card--ended' : ''}}"
        data-id="{{item.course_id}}"
        bindtap="onViewDetail"
      >
        <text class="my-courses__relation">{{item.relationLabel}}</text>
        <view class="my-courses__main">
          <view class="my-courses__cover">
            <image class="my-courses__cover-img" src="{{item.coverSrc}}" mode="aspectFill" />
          </view>
          <view class="my-courses__info">
            <view class="my-courses__info-top">
              <text class="my-courses__title">{{item.title}}</text>
              <text class="my-courses__type-tag my-courses__type-tag--course">{{item.typeLabel}}</text>
            </view>
            <text class="my-courses__time">{{item.timeDisplay}}</text>
            <text class="my-courses__place">{{item.placeLabel}}：{{item.location || '地点待定'}}</text>
            <text class="my-courses__fee {{item.listTab === 'ended' ? 'my-courses__fee--muted' : ''}}">¥{{item.price}}/人</text>
          </view>
        </view>
        <view class="my-courses__bar">
          <text class="my-courses__quota">{{item.quotaText}}</text>
          <view class="my-courses__actions" wx:if="{{item.canViewSignup}}">
            <view
              class="my-courses__btn my-courses__btn--primary"
              data-id="{{item.course_id}}"
              data-title="{{item.title}}"
              catchtap="onViewMembers"
            >已报名成员</view>
          </view>
        </view>
      </view>
    </block>

    <view wx:if="{{currentList.length === 0}}" class="my-courses__empty">
      <image class="my-courses__empty-icon" src="{{emptyState.icon}}" mode="aspectFit" />
      <text class="my-courses__empty-title">{{emptyState.title}}</text>
      <text class="my-courses__empty-hint">{{emptyState.hint}}</text>
    </view>
  </view>
</view>

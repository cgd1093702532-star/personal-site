@import "../../styles/common.wxss";

.apply-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--color-bg-subtle);
}

.apply-scroll {
  flex: 1;
  height: 0;
}

.apply {
  padding: 24rpx var(--space-page-x) 24rpx;
  background: var(--color-bg-subtle);
}

.apply-section {
  margin-bottom: 24rpx;
  padding: 28rpx;
  background: var(--color-bg-page);
  border-radius: var(--radius-md);
}

.apply-section__title {
  display: block;
  margin-bottom: 24rpx;
  font-size: var(--text-body);
  font-weight: 600;
  text-align: left;
  color: var(--color-text-primary);
}

.apply-field {
  margin-bottom: 28rpx;
}

.apply-field:last-child {
  margin-bottom: 0;
}

.apply-label {
  display: block;
  margin-bottom: 12rpx;
  font-size: var(--text-caption);
  color: var(--color-text-secondary);
}

.apply-label--required::after {
  content: ' *';
  color: var(--color-price);
}

.apply-field__hint {
  display: block;
  margin: -4rpx 0 16rpx;
  font-size: var(--text-micro);
  line-height: 1.4;
  color: #999999;
}

.apply-input,
.apply-picker {
  height: 80rpx;
  padding: 0 24rpx;
  background: var(--color-bg-gray);
  border-radius: var(--radius-md);
  font-size: var(--text-body);
  line-height: 80rpx;
  color: var(--color-text-body);
}

.apply-picker--placeholder {
  color: #999999;
}

.apply-placeholder {
  color: #999999;
}

.apply-cert-sheet {
  position: fixed;
  inset: 0;
  z-index: 2000;
}

.apply-cert-sheet__mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
}

.apply-cert-sheet__panel {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 32rpx calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
}

.apply-cert-sheet__title {
  display: block;
  padding: 24rpx 16rpx 8rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  text-align: center;
}

.apply-cert-sheet__header {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  padding: 8rpx 24rpx 0;
}

.apply-cert-sheet__header .apply-cert-sheet__title {
  flex: 1;
  padding: 24rpx 112rpx 16rpx;
}

.apply-cert-sheet__done {
  position: absolute;
  top: 50%;
  right: 8rpx;
  transform: translateY(-50%);
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  line-height: 1;
  color: var(--color-primary);
}

.apply-cert-sheet__item {
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  font-size: 30rpx;
  color: var(--color-text-primary);
  border-bottom: 1rpx solid var(--color-divider);
}

.apply-cert-sheet__item:last-child {
  border-bottom: none;
}

.apply-cert-sheet__item--active {
  position: relative;
  color: var(--color-primary);
  font-weight: 600;
  background: rgba(27, 87, 156, 0.1);
}

.apply-cert-sheet__item--active::after {
  content: '✓';
  position: absolute;
  right: 40rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1;
  color: var(--color-primary);
}

.apply-cert-sheet__item--cancel {
  margin-top: 8rpx;
  color: var(--color-text-secondary);
}

.apply-cert-sheet__item:active {
  background: var(--color-bg-subtle);
}

.apply-input--phone {
  flex: 1;
  min-width: 0;
  background: transparent;
}

.apply-phone-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding-right: 24rpx;
  background: var(--color-bg-gray);
  border-radius: var(--radius-md);
}

.apply-sms-code {
  flex-shrink: 0;
  font-size: var(--text-caption);
  color: var(--color-text-muted);
  font-weight: 500;
  white-space: nowrap;
}

.apply-sms-code--active {
  color: var(--color-primary);
}

.apply-sms-code--active:active {
  opacity: 0.75;
}

.apply-sms-code--countdown {
  color: var(--color-text-muted);
}

.apply-sms-field {
  display: none;
  margin-top: 16rpx;
}

.apply-sms-field--visible {
  display: block;
}

.apply-phone-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.apply-phone-change {
  flex-shrink: 0;
  padding: 0 24rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: var(--radius-md);
  background: rgba(27, 87, 156, 0.1);
  font-size: var(--text-caption);
  color: var(--color-primary);
  font-weight: 500;
}

.apply-phone-change:active {
  opacity: 0.85;
}

.apply-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.apply-tag {
  padding: 12rpx 24rpx;
  background: var(--color-bg-gray);
  border-radius: var(--radius-pill);
  font-size: var(--text-caption);
  color: var(--color-text-body);
  border: 1rpx solid transparent;
}

.apply-tag--active {
  background: rgba(27, 87, 156, 0.1);
  color: var(--color-primary);
  border-color: var(--color-primary);
  font-weight: 500;
}

.apply-cert-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.apply-cert-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.apply-cert-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 16rpx;
  border-radius: 20rpx;
  background: var(--color-bg-gray);
  box-sizing: border-box;
}

.apply-cert-row__thumb,
.apply-cert-row__placeholder {
  width: 128rpx;
  height: 128rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: var(--color-bg-gray);
}

.apply-cert-row__name {
  flex: 1;
  min-width: 0;
  height: 80rpx;
  padding: 0 24rpx;
  border: 1rpx solid var(--color-divider);
  border-radius: 16rpx;
  background: #fff;
  font-size: 28rpx;
  color: var(--color-text-primary);
  box-sizing: border-box;
}

.apply-cert-row__remove {
  flex-shrink: 0;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.45);
  color: #fff;
  font-size: 32rpx;
  line-height: 56rpx;
  text-align: center;
}

.apply-cert-add--row {
  width: 100%;
  aspect-ratio: auto;
  min-height: 96rpx;
  flex-direction: row;
  gap: 12rpx;
  border-radius: 20rpx;
}

.apply-cert-name-dialog__preview {
  display: block;
  width: 240rpx;
  height: 240rpx;
  margin: 0 auto 24rpx;
  border-radius: 16rpx;
}

.apply-cert-item,
.apply-cert-add {
  width: calc((100% - 32rpx) / 3);
  aspect-ratio: 1;
  border-radius: var(--radius-md);
  overflow: hidden;
}

.apply-cert-add.apply-cert-add--row {
  width: 100%;
  aspect-ratio: auto;
  min-height: 96rpx;
  flex-direction: row;
  gap: 12rpx;
  border-radius: 20rpx;
}

.apply-cert-item {
  position: relative;
  background: var(--color-bg-gray);
}

.apply-cert-item__img,
.apply-cert-item__placeholder {
  width: 100%;
  height: 100%;
  pointer-events: none;
}

.apply-cert-item__label {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 8rpx;
  text-align: center;
  font-size: var(--text-micro);
  color: var(--color-text-inverse);
  background: rgba(0, 0, 0, 0.45);
  pointer-events: none;
}

.apply-cert-item__remove {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  z-index: 2;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.55);
  color: #fff;
  font-size: 28rpx;
  line-height: 40rpx;
  text-align: center;
}

.apply-cert-add {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  border: 2rpx dashed var(--color-divider);
  background: var(--color-bg-gray);
}

.apply-cert-add__icon {
  font-size: 40rpx;
  color: var(--color-text-secondary);
  line-height: 1;
}

.apply-cert-add__text {
  font-size: var(--text-micro);
  color: var(--color-text-secondary);
}

.apply-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 24rpx;
  box-sizing: border-box;
  background: var(--color-bg-gray);
  border-radius: var(--radius-md);
  font-size: var(--text-body);
  line-height: 40rpx;
  color: var(--color-text-body);
}

.apply-textarea--lg {
  min-height: 240rpx;
}

.apply-textarea--autosize {
  min-height: 160rpx;
}

.apply-textarea-wrap {
  position: relative;
}

.apply-textarea-wrap .apply-textarea {
  padding-bottom: 56rpx;
}

.apply-textarea-count {
  position: absolute;
  right: 24rpx;
  bottom: 16rpx;
  z-index: 1;
  margin: 0;
  font-size: var(--text-micro);
  line-height: 1;
  color: var(--color-text-secondary);
  pointer-events: none;
}

.apply-showcase-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.apply-showcase-section {
  padding: 24rpx;
  border: 1rpx solid var(--color-divider);
  border-radius: var(--radius-md);
  background: var(--color-bg-gray);
}

.apply-showcase-section__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.apply-showcase-section__title {
  font-size: var(--text-body);
  font-weight: 600;
  color: var(--color-text-primary);
}

.apply-showcase-section__title-input {
  flex: 1;
  min-width: 0;
  height: 72rpx;
  padding: 0 20rpx;
  border: 1rpx solid var(--color-divider);
  border-radius: var(--radius-md);
  background: #fff;
  font-size: var(--text-body);
  color: var(--color-text-primary);
}

.apply-showcase-section__remove,
.apply-showcase-add {
  flex-shrink: 0;
  font-size: var(--text-caption);
  color: var(--color-primary);
}

.apply-showcase-add {
  display: inline-block;
  margin-top: 16rpx;
}

.apply-showcase-grid {
  margin-bottom: 8rpx;
}

.apply-showcase-media {
  margin-top: 32rpx;
  padding: 20rpx;
  border: 1rpx dashed rgba(27, 87, 156, 0.35);
  border-radius: var(--radius-md);
  background: #fff;
}

.apply-showcase-media-hint {
  display: block;
  margin: 16rpx 0 0;
  font-size: var(--text-micro);
  line-height: 1.4;
  color: #999999;
  text-align: left;
}

.apply-showcase-media--video {
  padding: 0;
  overflow: hidden;
}

.apply-showcase-section .apply-textarea-wrap .apply-textarea {
  background: #fff;
  border: 1rpx solid var(--color-divider);
}

.apply-showcase-section .apply-cert-add {
  border-color: rgba(27, 87, 156, 0.28);
  background: rgba(27, 87, 156, 0.04);
}

.apply-showcase-section .apply-cert-add__icon,
.apply-showcase-section .apply-cert-add__text {
  color: var(--color-primary);
}

.apply-showcase-video-fill {
  position: relative;
  width: 100%;
  aspect-ratio: 16 / 9;
  min-height: 320rpx;
  background: #1c1c1e;
}

.apply-showcase-video-fill__media {
  width: 100%;
  height: 100%;
  display: block;
  pointer-events: none;
}

.apply-showcase-video-fill__duration {
  position: absolute;
  right: 16rpx;
  bottom: 16rpx;
  z-index: 1;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background: rgba(0, 0, 0, 0.55);
  color: #fff;
  font-size: var(--text-micro);
  line-height: 1.2;
  pointer-events: none;
}

.apply-showcase-video-fill__remove {
  top: 16rpx;
  right: 16rpx;
}

.apply-showcase-item--video {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #1c1c1e;
}

.apply-showcase-video-label {
  font-size: var(--text-micro);
  font-weight: 600;
  color: #fff;
}

.apply-showcase-item .apply-cert-item__img {
  pointer-events: none;
}

.apply-showcase-mode-switch {
  display: block;
  width: 100%;
  margin-top: 8rpx;
  font-size: var(--text-caption);
  color: var(--color-primary);
  text-align: center;
}

.apply-showcase-video {
  position: relative;
  min-height: 200rpx;
  padding: 32rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: #fff;
  border: 2rpx dashed var(--color-divider);
  border-radius: var(--radius-md);
}

.apply-showcase-video--selected {
  border-style: solid;
}

.apply-showcase-video__remove {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  z-index: 2;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.55);
  color: #fff;
  font-size: 28rpx;
  line-height: 40rpx;
  text-align: center;
}

.apply-showcase-video__reselect {
  position: absolute;
  inset: 0;
  z-index: 1;
}

.apply-textarea--city {
  min-height: 80rpx;
  padding: 20rpx 24rpx;
  line-height: 40rpx;
  box-sizing: border-box;
}

.apply-video {
  min-height: 200rpx;
  padding: 32rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: var(--color-bg-gray);
  border: 2rpx dashed var(--color-divider);
  border-radius: var(--radius-md);
}

.apply-video__icon {
  width: 48rpx;
  height: 48rpx;
}

.apply-video__hint,
.apply-video__selected {
  font-size: var(--text-caption);
  color: var(--color-text-secondary);
  text-align: center;
  line-height: 36rpx;
}

.apply-agreement {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin: 8rpx 0 32rpx;
}

.apply-agreement__check {
  flex-shrink: 0;
  width: 36rpx;
  height: 36rpx;
  margin-top: 4rpx;
  border-radius: 50%;
  border: 2rpx solid var(--color-divider);
  background: var(--color-bg-page);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: var(--color-text-inverse);
  line-height: 1;
}

.apply-agreement__check--on {
  background: var(--color-primary);
  border-color: var(--color-primary);
}

.apply-agreement__text {
  flex: 1;
  font-size: var(--text-caption);
  color: var(--color-text-secondary);
  line-height: 36rpx;
}

.apply-agreement__link {
  color: var(--color-primary);
  font-weight: 500;
}

.apply-footer {
  flex-shrink: 0;
  padding: 16rpx var(--space-page-x) calc(16rpx + env(safe-area-inset-bottom));
  background: var(--color-bg-subtle);
}

.apply-footer .apply-agreement {
  margin-bottom: 16rpx;
}

.apply-submit {
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: var(--color-primary);
  color: var(--color-text-inverse);
  border-radius: var(--radius-md);
  font-size: var(--text-card-title);
  font-weight: 600;
  border: none;
  padding: 0;
  margin: 0;
  width: 100%;
}

.apply-submit--ghost {
  margin-bottom: 20rpx;
  background: #fff;
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
  font-weight: 500;
}

.apply-submit:active {
  opacity: 0.9;
}

.profile-dialog {
  position: fixed;
  inset: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}

.profile-dialog__mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
}

.profile-dialog__panel {
  position: relative;
  z-index: 1;
  width: 560rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}

.profile-dialog__title {
  display: block;
  padding: 40rpx 40rpx 16rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  text-align: center;
}

.profile-dialog__body {
  display: block;
  padding: 0 40rpx 40rpx;
}

.profile-dialog__input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  border: 2rpx solid var(--color-divider);
  border-radius: 12rpx;
  background: var(--color-bg-gray);
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.profile-dialog__actions {
  display: flex;
  border-top: 1rpx solid var(--color-divider);
}

.profile-dialog__btn {
  flex: 1;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
  color: var(--color-text-secondary);
}

.profile-dialog__btn + .profile-dialog__btn {
  border-left: 1rpx solid var(--color-divider);
}

.profile-dialog__btn--primary {
  color: var(--color-primary);
  font-weight: 600;
}

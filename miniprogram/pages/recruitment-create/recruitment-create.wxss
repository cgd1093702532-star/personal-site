@import "../../styles/common.wxss";

.recruit-publish {
  min-height: 100vh;
  padding: 0 0 calc(32rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: var(--color-bg-page);
}

.recruit-publish__chrome {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: var(--color-bg-page);
  box-shadow: 0 1rpx 0 var(--color-divider);
}

.recruit-publish__navbar {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.recruit-publish__back {
  position: absolute;
  left: 8rpx;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  font-weight: 300;
  color: var(--color-text-primary);
}

.recruit-publish__nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.recruit-publish__body {
  box-sizing: border-box;
}

.my-recruit__tabs {
  display: flex;
  gap: 0;
  margin: 24rpx var(--space-page-x) 0;
  padding: 6rpx;
  background: #f0f0f0;
  border-radius: 20rpx;
}

.my-recruit__tab {
  flex: 1;
  padding: 16rpx 8rpx;
  text-align: center;
  font-size: 28rpx;
  line-height: 1.2;
  color: #666666;
  white-space: nowrap;
  border-radius: 16rpx;
  background: transparent;
}

.my-recruit__tab--active {
  color: #333333;
  font-weight: 600;
  background: #ffffff;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.08);
}

.recruit-publish__list {
  padding: 24rpx var(--space-page-x) 0;
}

.recruit-publish__list .event-card:last-child {
  margin-bottom: 0;
}

.recruit-publish__empty {
  padding: 80rpx 32rpx;
  text-align: center;
  font-size: var(--text-body);
  color: var(--color-text-secondary);
}

.profile-dialog {
  position: fixed;
  inset: 0;
  z-index: 2000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}

.profile-dialog__mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
}

.profile-dialog__panel {
  position: relative;
  z-index: 1;
  width: 560rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.18);
}

.profile-dialog__title {
  display: block;
  padding: 40rpx 40rpx 16rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  text-align: center;
}

.profile-dialog__body {
  display: block;
  padding: 0 40rpx 32rpx;
  font-size: 28rpx;
  line-height: 1.5;
  color: var(--color-text-body);
  text-align: center;
  word-break: break-word;
}

.profile-dialog__actions {
  display: flex;
  border-top: 1rpx solid var(--color-divider);
}

.profile-dialog__btn {
  flex: 1;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  font-size: 30rpx;
  color: var(--color-text-secondary);
}

.profile-dialog__btn + .profile-dialog__btn {
  border-left: 1rpx solid var(--color-divider);
}

.profile-dialog__btn--primary {
  color: var(--color-primary);
  font-weight: 600;
}

.profile-dialog__btn:active {
  background: var(--color-bg-subtle);
}

<view class="page page--tab heroes {{emptyKind ? 'heroes--empty' : ''}}">
  <view class="heroes-search">
    <view class="heroes-search__field">
      <input
        class="heroes-search__input"
        placeholder="搜索教练昵称、姓名或项目名称"
        value="{{keyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearchConfirm"
        confirm-type="search"
      />
      <text wx:if="{{keyword}}" class="heroes-search__clear" bindtap="onSearchClear">×</text>
    </view>
  </view>

  <view class="heroes-banner" wx:if="{{!keyword && heroes.length > 0}}">
    <image class="heroes-banner__img" src="/assets/images/heroes-banner.png" mode="aspectFill" />
  </view>

  <view class="heroes-list">
    <view wx:if="{{keyword && heroes.length > 0}}" class="heroes-result-hint">找到 {{heroes.length}} 位教练</view>

    <hero-card
      wx:for="{{heroes}}"
      wx:key="hero_id"
      hero="{{item}}"
      layout="list"
      bind:tap="onHeroTap"
    />

    <view wx:if="{{heroes.length === 0 && emptyKind === 'search'}}" class="heroes-empty">
      <image class="heroes-empty__icon" src="/assets/icons/search.png" mode="aspectFit" />
      <text class="heroes-empty__title">未找到相关教练和项目</text>
      <text class="heroes-empty__hint">试试调整搜索词</text>
    </view>
    <view wx:elif="{{heroes.length === 0}}" class="heroes-empty">
      <image class="heroes-empty__icon" src="/assets/icons/empty.png" mode="aspectFit" />
      <text class="heroes-empty__title">广场暂无数据</text>
    </view>
  </view>
</view>

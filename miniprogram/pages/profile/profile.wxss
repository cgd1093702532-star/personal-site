@import "../../styles/common.wxss";

.profile {
  padding: 32rpx var(--space-page-x);
}

.profile-user {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.profile-user__head {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.profile-user__avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.profile-user__name {
  display: block;
  font-size: var(--text-section-title);
  font-weight: 600;
  color: var(--color-text-primary);
}

.profile-user__member {
  font-size: var(--text-body);
  color: var(--color-text-secondary);
}

.profile-user__meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 8rpx;
}

.profile-user__cert {
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  font-size: var(--text-caption);
  font-weight: 500;
}

.profile-user__cert--tap {
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
}

.profile-user__cert--tap:active {
  opacity: 0.75;
}

.profile-user__cert-arrow {
  font-size: 22rpx;
  line-height: 1;
  opacity: 0.75;
}

.profile-user__cert--none {
  background: #f0f2f5;
  color: var(--color-text-secondary);
}

.profile-user__cert--hero {
  background: #e8f5e9;
  color: #09633f;
}

.profile-user__stats {
  display: flex;
  justify-content: space-around;
  padding: 24rpx;
  background: var(--color-bg-subtle);
  border-radius: var(--radius-md);
}

.profile-user__stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.profile-user__stat--tap:active {
  opacity: 0.7;
}

.profile-user__stat-num {
  font-size: var(--text-section-title);
  font-weight: 600;
  color: var(--color-text-primary);
}

.profile-user__stat-label {
  font-size: var(--text-caption);
  color: var(--color-text-secondary);
}

.profile-hero-center {
  margin-top: 32rpx;
  margin-bottom: 12rpx;
}

.profile-hero-shortcuts {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.profile-hero-shortcuts__row {
  display: flex;
  gap: 16rpx;
}

.profile-hero-shortcuts__item {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx 8rpx;
  background: linear-gradient(180deg, #eef4ff 0%, #f6f9ff 100%);
  border: 1rpx solid rgba(27, 87, 156, 0.12);
  border-radius: var(--radius-md);
  box-shadow: 0 4rpx 16rpx rgba(27, 87, 156, 0.08);
}

.profile-hero-shortcuts__row--secondary .profile-hero-shortcuts__item {
  flex: 0 0 calc((100% - 32rpx) / 3);
}

.profile-hero-shortcuts__item:active {
  opacity: 0.85;
}

.profile-hero-shortcuts__icon {
  font-size: 40rpx;
  line-height: 1;
}

.profile-hero-shortcuts__label {
  font-size: var(--text-micro);
  font-weight: 500;
  color: var(--color-text-primary);
  text-align: center;
  line-height: 28rpx;
}

.profile-dev-toggle {
  margin-top: 24rpx;
  padding: 16rpx 24rpx;
  text-align: center;
  font-size: var(--text-caption);
  color: var(--color-text-secondary);
  background: var(--color-bg-subtle);
  border: 1rpx dashed var(--color-divider);
  border-radius: var(--radius-md);
}

.profile-dev-toggle:active {
  opacity: 0.85;
}

.profile-hero-cta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 32rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #fff9e6 0%, #fff3cc 100%);
  border: 2rpx solid var(--color-accent);
  border-radius: var(--radius-md);
  box-shadow: 0 8rpx 24rpx rgba(254, 207, 19, 0.2);
}

.profile-hero-cta--pending {
  background: var(--color-bg-subtle);
  border-color: var(--color-divider);
  box-shadow: none;
}

.profile-hero-cta__hint {
  flex: 1;
  min-width: 0;
  font-size: var(--text-caption);
  line-height: 36rpx;
  color: var(--color-text-body);
}

.profile-hero-cta__btn {
  flex-shrink: 0;
  padding: 20rpx 28rpx;
  background: var(--color-accent);
  border-radius: var(--radius-md);
  font-size: var(--text-body);
  font-weight: 600;
  color: var(--color-text-primary);
  box-shadow: 0 4rpx 12rpx rgba(254, 207, 19, 0.35);
}

.profile-hero-cta__btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.profile-section {
  margin-top: 48rpx;
}

.profile-section--disabled {
  opacity: 0.45;
}

.profile-section__title {
  display: block;
  margin-bottom: 16rpx;
  font-size: var(--text-body);
  font-weight: 600;
  text-align: left;
  color: var(--color-text-primary);
}

.profile-menu__item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx 0;
  border-bottom: 1rpx solid var(--color-divider);
}

.profile-menu__icon {
  width: 72rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  border-radius: var(--radius-md);
  background: var(--color-bg-subtle);
  font-size: 32rpx;
  flex-shrink: 0;
}

.profile-menu__body {
  flex: 1;
  min-width: 0;
}

.profile-menu__title {
  display: block;
  font-size: var(--text-card-title);
  color: var(--color-text-primary);
}

.profile-menu__desc {
  display: block;
  margin-top: 4rpx;
  font-size: var(--text-caption);
  color: var(--color-text-secondary);
}

.profile-menu__arrow {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  flex-shrink: 0;
}

.profile-action-sheet {
  position: fixed;
  inset: 0;
  z-index: 2000;
}

.profile-action-sheet__mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
}

.profile-action-sheet__panel {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx var(--space-page-x) calc(16rpx + env(safe-area-inset-bottom));
  background: var(--color-bg-page);
  border-radius: 24rpx 24rpx 0 0;
}

.profile-action-sheet__item {
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  font-size: var(--text-body);
  color: var(--color-text-primary);
  border-bottom: 1rpx solid var(--color-divider);
}

.profile-action-sheet__item:last-child {
  border-bottom: none;
}

.profile-action-sheet__item:active {
  background: var(--color-bg-subtle);
}

.profile-action-sheet__item--cancel {
  margin-top: 8rpx;
  border-radius: var(--radius-md);
  border-bottom: none;
  color: var(--color-text-secondary);
}

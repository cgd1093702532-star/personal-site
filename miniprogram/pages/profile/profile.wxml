<view class="page page--tab profile">
  <view class="profile-user">
    <view class="profile-user__head">
      <view class="profile-user__avatar cover-placeholder"></view>
      <view class="profile-user__info">
        <text class="profile-user__name">{{user.nickname}}</text>
        <view class="profile-user__meta">
          <text class="profile-user__member">{{user.member}}</text>
          <text wx:if="{{!isHero}}" class="profile-user__cert profile-user__cert--none">未认证</text>
          <view wx:else class="profile-user__cert profile-user__cert--hero profile-user__cert--tap" bindtap="onHeroCertSuccess">
            <text class="profile-user__cert-text">已认证英雄</text>
          </view>
        </view>
      </view>
    </view>
    <view class="profile-user__stats" wx:if="{{isHero}}">
      <view class="profile-user__stat profile-user__stat--tap" bindtap="onMyStudents">
        <text class="profile-user__stat-num">{{hero.student_count}}</text>
        <text class="profile-user__stat-label">学员</text>
      </view>
      <view class="profile-user__stat profile-user__stat--tap" bindtap="onMyRatings">
        <text class="profile-user__stat-num">{{hero.rating}}</text>
        <text class="profile-user__stat-label">评分</text>
      </view>
      <view class="profile-user__stat profile-user__stat--tap" bindtap="onMyCourses">
        <text class="profile-user__stat-num">{{hero.course_count}}</text>
        <text class="profile-user__stat-label">课程</text>
      </view>
    </view>
  </view>

  <view wx:if="{{!isHero}}" class="profile-hero-cta {{heroPending ? 'profile-hero-cta--pending' : ''}} {{heroRejected ? 'profile-hero-cta--rejected' : ''}}">
    <text class="profile-hero-cta__hint">{{ctaHint}}</text>
    <view class="profile-hero-cta__btn" bindtap="onApplyHero">{{ctaBtn}}</view>
  </view>

  <view class="profile-orders">
    <view class="profile-orders__head">
      <text class="profile-orders__title">我的订单</text>
      <text class="profile-orders__more">全部订单 ›</text>
    </view>
    <view class="profile-orders__grid">
      <view class="profile-orders__item">
        <image class="profile-orders__icon" src="/assets/icons/order-pay.png" mode="aspectFit" />
        <text class="profile-orders__label">待付款</text>
      </view>
      <view class="profile-orders__item">
        <image class="profile-orders__icon" src="/assets/icons/order-ship.png" mode="aspectFit" />
        <text class="profile-orders__label">待发货</text>
      </view>
      <view class="profile-orders__item">
        <image class="profile-orders__icon" src="/assets/icons/order-receive.png" mode="aspectFit" />
        <text class="profile-orders__label">待使用/待收货</text>
      </view>
      <view class="profile-orders__item">
        <image class="profile-orders__icon" src="/assets/icons/order-refund.png" mode="aspectFit" />
        <text class="profile-orders__label">退款/售后</text>
      </view>
    </view>
  </view>

  <view wx:if="{{isHero}}" class="profile-hero-center">
    <text class="profile-section__title">服务中心</text>
    <view class="profile-hero-shortcuts">
      <view class="profile-hero-shortcuts__row">
        <view class="profile-hero-shortcuts__item" bindtap="onMyRecruitments">
          <image class="profile-hero-shortcuts__icon" src="/assets/icons/list.png" mode="aspectFit" />
          <text class="profile-hero-shortcuts__label">我的招募</text>
        </view>
        <view class="profile-hero-shortcuts__item" bindtap="onMyCourses">
          <image class="profile-hero-shortcuts__icon" src="/assets/icons/book.png" mode="aspectFit" />
          <text class="profile-hero-shortcuts__label">我的课程</text>
        </view>
        <view class="profile-hero-shortcuts__item" bindtap="onHeroProfile">
          <image class="profile-hero-shortcuts__icon" src="/assets/icons/user.png" mode="aspectFit" />
          <text class="profile-hero-shortcuts__label">英雄资料</text>
        </view>
      </view>
    </view>
  </view>

  <view class="profile-section">
    <text class="profile-section__title">我的活动</text>
    <view class="profile-menu__item" bindtap="onMySignups">
      <view class="profile-menu__icon">
        <image class="icon icon--md" src="/assets/icons/list.png" mode="aspectFit" />
      </view>
      <view class="profile-menu__body">
        <text class="profile-menu__title">我的报名</text>
      </view>
      <text class="profile-menu__arrow">›</text>
    </view>
    <view class="profile-menu__item" bindtap="onMyReviews">
      <view class="profile-menu__icon">
        <image class="icon icon--md" src="/assets/icons/star.png" mode="aspectFit" />
      </view>
      <view class="profile-menu__body">
        <text class="profile-menu__title">我的评价</text>
      </view>
      <text class="profile-menu__arrow">›</text>
    </view>
  </view>
</view>
